[sub_resource type="GDScript" id="GDScript_hh3co"]
script/source = "extends Node

func _ready() -> void:
	# Wait one frame for autoloads to initialize
	await get_tree().process_frame
	await get_tree().process_frame
	
	# Open recycler panel
	var recycler_scene := load(\"res://scenes/ui/recycler_panel.tscn\") as PackedScene
	var recycler := recycler_scene.instantiate()
	add_child(recycler)
	recycler.open()
	print(\"TEST: RecyclerPanel opened successfully\")
"

