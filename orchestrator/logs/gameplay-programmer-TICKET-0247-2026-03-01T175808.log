lay-programmer-TICKET-0247\\game\\scripts\\levels\\test_world.gd:41:var _travel_manager: TravelSequenceManager = null\nC:\\repos\\Hammer-Forge-Studio\\.claude\\worktrees\\orch-gameplay-programmer-TICKET-0247\\game\\scripts\\levels\\test_world.gd:99:\t# TravelSequenceManager swaps this container's children on biome travel.\nC:\\repos\\Hammer-Forge-Studio\\.claude\\worktrees\\orch-gameplay-programmer-TICKET-0247\\game\\scripts\\levels\\test_world.gd:549:\t_travel_manager = TravelSequenceManager.new()\nC:\\repos\\Hammer-Forge-Studio\\.claude\\worktrees\\orch-gameplay-programmer-TICKET-0247\\game\\scripts\\levels\\test_world.gd:550:\t_travel_manager.name = \"TravelSequenceManager\"\nC:\\repos\\Hammer-Forge-Studio\\.claude\\worktrees\\orch-gameplay-programmer-TICKET-0247\\game\\scripts\\gameplay\\travel_sequence_manager.gd:1:## TravelSequenceManager - Orchestrates inter-biome travel transitions: fade to black,\nC:\\repos\\Hammer-Forge-Studio\\.claude\\worktrees\\orch-gameplay-programmer-TICKET-0247\\game\\scripts\\gameplay\\travel_sequence_manager.gd:5:class_name TravelSequenceManager\nC:\\repos\\Hammer-Forge-Studio\\.claude\\worktrees\\orch-gameplay-programmer-TICKET-0247\\game\\scripts\\gameplay\\travel_sequence_manager.gd:58:\tGlobal.log(\"TravelSequenceManager: setup complete\")\nC:\\repos\\Hammer-Forge-Studio\\.claude\\worktrees\\orch-gameplay-programmer-TICKET-0247\\game\\scripts\\gameplay\\travel_sequence_manager.gd:83:\t\tpush_error(\"TravelSequenceManager: unknown biome '%s' — swap aborted\" % destination_id)\nC:\\repos\\Hammer-Forge-Studio\\.claude\\worktrees\\orch-gameplay-programmer-TICKET-0247\\game\\scripts\\gameplay\\travel_sequence_manager.gd:105:\tGlobal.log(\"TravelSequenceManager: biome swap to '%s' complete\" % destination_id)\nC:\\repos\\Hammer-Forge-Studio\\.claude\\worktrees\\orch-gameplay-programmer-TICKET-0247\\game\\scripts\\gameplay\\travel_sequence_manager.gd:128:\tpush_warning(\"TravelSequenceManager: biome node has no player spawn method\")\