ull,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":429,"cache_read_input_tokens":39507,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":429},"output_tokens":25,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"e95448fc-7558-4157-960a-6c7229146ac9","uuid":"9d7dab52-76a5-4463-85f4-83d2fd803b58"},{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_01UEDqbf2jGsvxUHBovYMTRn","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01MDfZ3W6UATsZBYqyuhHR9t","name":"Grep","input":{"pattern":"TravelSequenceManager","type":"gd"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":3,"cache_creation_input_tokens":20322,"cache_read_input_tokens":0,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":20322},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":"toolu_01ApphtWBg4LCeYPCUHDVeb3","session_id":"e95448fc-7558-4157-960a-6c7229146ac9","uuid":"7842d6f8-13dd-49e6-9972-fc31888f0e0f"},{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Heq5gAu3b3YxpE9su3F1kq","type":"tool_result","content":"     1→## Navigation console modal: displays biome map, destination detail, fuel cost,\n     2→## and confirm travel button. Opens when the player interacts with the cockpit\n     3→## console mesh. Follows existing modal panel pattern (Fabricator, TechTree).\n     4→## Owner: gameplay-programmer\n     5→## Ticket: TICKET-0167\n     6→class_name NavigationConsole\n     7→extends CanvasLayer\n     8→\n     9→# ── Signals ──────────────────────────────────────────────\n    10→signal travel_confirmed(destination_biome_id: String)\n    11→signal panel_closed\n    12→\n    13→# ── Constants ─────────────────────────────────────────────\n    14→const PANEL_WIDTH: float = 900.0\n    15→const PANEL_HEIGHT: float = 600.0\n    16→const MAP_WIDTH: float = 540.0\n    17→const DETAIL_WIDTH: float = 300.0\n    18→const TITLE_HEIGHT: float = 56.0\n    19→const ACTION_HEIGHT: float = 60.0\n    20→\n    21→## Style colors matching UI style guide\n    22→const COLOR_SURFACE := Color(\"#0A0F18\", 0.95)\n    23→const COLOR_BORDER := Color(\"#007A63\")\n    24→const COLOR_TEAL := Color(\"#00D4AA\")\n    25→const COLOR_AMBER := Color(\"#FFB830\")\n    26→const COLOR_CORAL := Color(\"#FF6B5A\")\n    27→const COLOR_GREEN := Color(\"#4ADE80\")\n    28→const COLOR_TEXT_PRIMARY := Color(\"#F1F5F9\")\n    29→const COLOR_TEXT_SECONDARY := Color(\"#94A3B8\")\n    30→const COLOR_NEUTRAL := Color(\"#94A3B8\")\n    31→const COLOR_DIM := Color(\"#000000\", 0.5)\n    32→const COLOR_PANEL_BG := Color(\"#0F1923\", 0.85)\n    33→const COLOR_NODE_BG := Color(\"#1A2736\", 0.7)\n    34→const COLOR_NODE_BG_SELECTED := Color(\"#1A2736\", 0.9)\n    35→\n    36→# ── Private Variables ─────────────────────────────────────\n    37→var _is_open: bool = false\n    38→var _dim_rect: ColorRect = null\n    39→var _main_panel: PanelContainer = null\n    40→var _selected_biome_id: String = \"\"\n    41→var _biome_node_buttons: Dictionary = {}\n    42→var _biome_node_ids: Array[String] = []\n    43→var _selected_index: int = -1\n    44→var _focus_on_map: bool = true\n    45→\n    46→## Detail panel elements\n    47→var _detail_name_label: Label = null\n    48→var _detail_tier_label: Label = null\n    49→var _detail_distance_label: Label = null\n    50→var _detail_distance_value: Label = null\n    51→var _detail_fuel_cost_label: Label = null\n    52→var _detail_fuel_cost_value: Label = null\n    53→var _detail_your_fuel_label: Label = null\n    54→var _detail_your_fuel_value: Label = null\n    55→var _detail_sufficiency_label: Label = null\n    56→var _confirm_button: Button = null\n    57→var _confirm_disabled_reason: Label = null\n    58→var _cancel_button: Button = null\n    59→var _detail_prompt_label: Label = null\n    60→var _detail_container: ScrollContainer = null\n    61→\n    62→## Ship fuel section elements\n    63→var _fuel_tank_level_label: Label = null\n    64→var _fuel_inventory_count_label: Label = null\n    65→var _load_fuel_button: Button = null\n    66→var _fuel_status_label: Label = null\n    67→\n    68→## Current biome node display\n    69→var _current_biome_label: Label = null\n    70→\n    71→# ── Built-in Virtual Methods ──────────────────────────────\n    72→\n    73→func _ready() -> void:\n    74→\tlayer = 2\n    75→\tprocess_mode = Node.PROCESS_MODE_INHERIT\n    76→\tvisible = false\n    77→\t_build_ui()\n    78→\t_connect_signals()\n    79→\n    80→func _input(event: InputEvent) -> void:\n    81→\tif not _is_open:\n    82→\t\treturn\n    83→\tif event.is_action_pressed(\"ui_cancel\"):\n    84→\t\tclose_panel()\n    85→\t\tget_viewport().set_input_as_handled()\n    86→\t\treturn\n    87→\n    88→\tif _focus_on_map:\n    89→\t\tif event.is_action_pressed(\"ui_left\"):\n    90→\t\t\t_move_map_focus(-1)\n    91→\t\t\tget_viewport().set_input_as_handled()\n    92→\t\telif event.is_action_pressed(\"ui_right\"):\n    93→\t\t\t_move_map_focus(1)\n    94→\t\t\tget_viewport().set_input_as_handled()\n    95→\t\telif event.is_action_pressed(\"ui_down\"):\n    96→\t\t\t# Move focus from map to confirm/cancel buttons\n    97→\t\t\t_focus_on_map = false\n    98→\t\t\tif _confirm_button and not _confirm_button.disabled:\n    99→\t\t\t\t_confirm_button.grab_focus()\n   100→\t\t\telif _cancel_button:\n   101→\t\t\t\t_cancel_button.grab_focus()\n   102→\t\t\tget_viewport().set_input_as_handled()\n   103→\t\telif event.is_action_pressed(\"ui_up\"):\n   104→\t\t\t_move_map_focus(-1)\n   105→\t\t\tget_viewport().set_input_as_handled()\n   106→\t\telif event.is_action_pressed(\"ui_accept\"):\n   107→\t\t\t# Select focused destination and shift focus to confirm button\n   108→\t\t\tif _selected_index >= 0:\n   109→\t\t\t\t_select_biome(_biome_node_ids[_selected_index])\n   110→\t\t\t\t_focus_on_map = false\n   111→\t\t\t\tif _confirm_button and not _confirm_button.disabled:\n   112→\t\t\t\t\t_confirm_button.grab_focus()\n   113→\t\t\t\telif _cancel_button:\n   114→\t\t\t\t\t_cancel_button.grab_focus()\n   115→\t\t\tget_viewport().set_input_as_handled()\n   116→\telse:\n   117→\t\tif event.is_action_pressed(\"ui_up\") or event.is_action_pressed(\"ui_left\"):\n   118→\t\t\t_focus_on_map = true\n   119→\t\t\t_update_map_visuals()\n   120→\t\t\tget_viewport().set_input_as_handled()\n   121→\t\telif event.is_action_pressed(\"ui_down\"):\n   122→\t\t\t# Move between confirm and cancel\n   123→\t\t\tif _cancel_button:\n   124→\t\t\t\t_cancel_button.grab_focus()\n   125→\t\t\tget_viewport().set_input_as_handled()\n   126→\t\telif event.is_action_pressed(\"ui_accept\"):\n   127→\t\t\tif _confirm_button and _confirm_button.has_focus() and not _confirm_button.disabled:\n   128→\t\t\t\t_on_confirm_pressed()\n   129→\t\t\telif _cancel_button and _cancel_button.has_focus():\n   130→\t\t\t\tclose_panel()\n   131→\t\t\tget_viewport().set_input_as_handled()\n   132→\n   133→# ── Public Methods ────────────────────────────────────────\n   134→\n   135→## Opens the navigation console panel and resets to no-selection state.\n   136→func open_panel() -> void:\n   137→\tif _is_open:\n   138→\t\treturn\n   139→\t_is_open = true\n   140→\tvisible = true\n   141→\t_selected_biome_id = \"\"\n   142→\t_selected_index = -1\n   143→\t_focus_on_map = true\n   144→\t_clamp_panel_to_viewport()\n   145→\t_refresh_biome_nodes()\n   146→\t_refresh_detail()\n   147→\t_refresh_fuel_section()\n   148→\t# Auto-focus first available destination node\n   149→\tif _biome_node_ids.size() > 0:\n   150→\t\t_selected_index = 0\n   151→\t\t_update_map_visuals()\n   152→\tInputManager.set_gameplay_inputs_enabled(false)\n   153→\tInput.set_mouse_mode(Input.MOUSE_MODE_VISIBLE)\n   154→\t_animate_open()\n   155→\tGlobal.log(\"NavigationConsole: opened\")\n   156→\n   157→## Closes the navigation console panel and restores input handling.\n   158→func close_panel() -> void:\n   159→\tif not _is_open:\n   160→\t\treturn\n   161→\t_is_open = false\n   162→\tInputManager.set_gameplay_inputs_enabled(true)\n   163→\tInput.set_mouse_mode(Input.MOUSE_MODE_CAPTURED)\n   164→\t_animate_close()\n   165→\tpanel_closed.emit()\n   166→\tGlobal.log(\"NavigationConsole: closed\")\n   167→\n   168→## Closes the panel for travel without re-enabling gameplay inputs.\n   169→## The TravelSequenceManager owns the input state during the transition\n   170→## and will call InputManager.set_gameplay_inputs_enabled(true) when the\n   171→## travel sequence completes.\n   172→func _close_for_travel() -> void:\n   173→\tif not _is_open:\n   174→\t\treturn\n   175→\t_is_open = false\n   176→\tInput.set_mouse_mode(Input.MOUSE_MODE_CAPTURED)\n   177→\t_animate_close()\n   178→\tpanel_closed.emit()\n   179→\tGlobal.log(\"NavigationConsole: closed for travel (inputs left disabled)\")\n   180→\n   181→## Returns true if the panel is currently open.\n   182→func is_open() -> bool:\n   183→\treturn _is_open\n   184→\n   185→# ── Private Methods ───────────────────────────────────────\n   186→\n   187→func _build_ui() -> void:\n   188→\t# Dim background\n   189→\tvar dim_layer := Control.new()\n   190→\tdim_layer.set_anchors_preset(Control.PRESET_FULL_RECT)\n   191→\tdim_layer.mouse_filter = Control.MOUSE_FILTER_STOP\n   192→\tadd_child(dim_layer)\n   193→\n   194→\t_dim_rect = ColorRect.new()\n   195→\t_dim_rect.set_anchors_preset(Control.PRESET_FULL_RECT)\n   196→\t_dim_rect.color = COLOR_DIM\n   197→\tdim_layer.add_child(_dim_rect)\n   198→\n   199→\tvar center := CenterContainer.new()\n   200→\tcenter.set_anchors_preset(Control.PRESET_FULL_RECT)\n   201→\tdim_layer.add_child(center)\n   202→\n   203→\t# Main panel\n   204→\t_main_panel = PanelContainer.new()\n   205→\t_main_panel.custom_minimum_size = Vector2(PANEL_WIDTH, PANEL_HEIGHT)\n   206→\t_main_panel.pivot_offset = Vector2(PANEL_WIDTH / 2.0, PANEL_HEIGHT / 2.0)\n   207→\tvar panel_style := StyleBoxFlat.new()\n   208→\tpanel_style.bg_color = COLOR_SURFACE\n   209→\tpanel_style.border_color = COLOR_BORDER\n   210→\tpanel_style.set_border_width_all(1)\n   211→\tpanel_style.set_corner_radius_all(8)\n   212→\tpanel_style.set_content_margin_all(24)\n   213→\t_main_panel.add_theme_stylebox_override(\"panel\", panel_style)\n   214→\tcenter.add_child(_main_panel)\n   215→\n   216→\tvar outer_vbox := VBoxContainer.new()\n   217→\touter_vbox.add_theme_constant_override(\"separation\", 0)\n   218→\t_main_panel.add_child(outer_vbox)\n   219→\n   220→\t# Title bar\n   221→\t_build_title_bar(outer_vbox)\n   222→\t_add_divider(outer_vbox)\n   223→\n   224→\t# Content area: map (left) + detail (right)\n   225→\tvar content_hbox := HBoxContainer.new()\n   226→\tcontent_hbox.add_theme_constant_override(\"separation\", 16)\n   227→\tcontent_hbox.size_flags_vertical = Control.SIZE_EXPAND_FILL\n   228→\touter_vbox.add_child(content_hbox)\n   229→\n   230→\t# Left column: biome map\n   231→\tvar map_column := _build_map_column()\n   232→\tcontent_hbox.add_child(map_column)\n   233→\n   234→\t# Vertical divider\n   235→\tvar v_divider := VSeparator.new()\n   236→\tvar vdiv_style := StyleBoxFlat.new()\n   237→\tvdiv_style.bg_color = Color(COLOR_NEUTRAL, 0.3)\n   238→\tvdiv_style.set_content_margin_all(0)\n   239→\tv_divider.add_theme_stylebox_override(\"separator\", vdiv_style)\n   240→\tcontent_hbox.add_child(v_divider)\n   241→\n   242→\t# Right column: destination detail\n   243→\t_detail_container = _build_detail_column()\n   244→\tcontent_hbox.add_child(_detail_container)\n   245→\n   246→\t# Action bar (bottom)\n   247→\t_add_divider(outer_vbox)\n   248→\t_build_action_bar(outer_vbox)\n   249→\n   250→func _build_title_bar(parent: VBoxContainer) -> void:\n   251→\tvar title_row := HBoxContainer.new()\n   252→\ttitle_row.custom_minimum_size = Vector2(0, TITLE_HEIGHT)\n   253→\ttitle_row.add_theme_constant_override(\"separation\", 8)\n   254→\tparent.add_child(title_row)\n   255→\n   256→\tvar title := Label.new()\n   257→\ttitle.text = \"NAVIGATION CONSOLE\"\n   258→\ttitle.add_theme_font_size_override(\"font_size\", 32)\n   259→\ttitle.add_theme_color_override(\"font_color\", COLOR_TEXT_PRIMARY)\n   260→\ttitle.size_flags_horizontal = Control.SIZE_EXPAND_FILL\n   261→\ttitle.vertical_alignment = VERTICAL_ALIGNMENT_CENTER\n   262→\ttitle_row.add_child(title)\n   263→\n   264→\tvar close_button := Button.new()\n   265→\tclose_button.text = \"CLOSE\"\n   266→\tclose_button.custom_minimum_size = Vector2(80, 32)\n   267→\tclose_button.add_theme_font_size_override(\"font_size\", 16)\n   268→\t_style_secondary_button(close_button)\n   269→\tclose_button.pressed.connect(close_panel)\n   270→\ttitle_row.add_child(close_button)\n   271→\n   272→func _build_map_column() -> VBoxContainer:\n   273→\tvar col := VBoxContainer.new()\n   274→\tcol.custom_minimum_size = Vector2(MAP_WIDTH, 0)\n   275→\tcol.size_flags_horizontal = Control.SIZE_EXPAND_FILL\n   276→\tcol.add_theme_constant_override(\"separation\", 8)\n   277→\n   278→\t# Map section header\n   279→\tvar header := Label.new()\n   280→\theader.text = \"BIOME MAP\"\n   281→\theader.add_theme_font_size_override(\"font_size\", 14)\n   282→\theader.add_theme_color_override(\"font_color\", COLOR_TEXT_SECONDARY)\n   283→\tcol.add_child(header)\n   284→\n   285→\t# Map container with panel background\n   286→\tvar map_panel := PanelContainer.new()\n   287→\tmap_panel.size_flags_vertical = Control.SIZE_EXPAND_FILL\n   288→\tvar map_bg := StyleBoxFlat.new()\n   289→\tmap_bg.bg_color = COLOR_PANEL_BG\n   290→\tmap_bg.set_content_margin_all(20)\n   291→\tmap_bg.set_corner_radius_all(4)\n   292→\tmap_panel.add_theme_stylebox_override(\"panel\", map_bg)\n   293→\tcol.add_child(map_panel)\n   294→\n   295→\tvar map_vbox := VBoxContainer.new()\n   296→\tmap_vbox.add_theme_constant_override(\"separation\", 16)\n   297→\tmap_panel.add_child(map_vbox)\n   298→\n   299→\t# Current location node (displayed at top of map)\n   300→\t_current_biome_label = Label.new()\n   301→\t_current_biome_label.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER\n   302→\t_current_biome_label.add_theme_font_size_override(\"font_size\", 16)\n   303→\t_current_biome_label.add_theme_color_override(\"font_color\", COLOR_TEAL)\n   304→\n   305→\tvar current_node_panel := PanelContainer.new()\n   306→\tcurrent_node_panel.custom_minimum_size = Vector2(200, 40)\n   307→\tvar current_style := StyleBoxFlat.new()\n   308→\tcurrent_style.bg_color = Color(\"#1A2736\", 0.9)\n   309→\tcurrent_style.border_color = COLOR_TEAL\n   310→\tcurrent_style.set_border_width_all(2)\n   311→\tcurrent_style.set_corner_radius_all(4)\n   312→\tcurrent_style.set_content_margin_all(8)\n   313→\tcurrent_node_panel.add_theme_stylebox_override(\"panel\", current_style)\n   314→\tcurrent_node_panel.size_flags_horizontal = Control.SIZE_SHRINK_CENTER\n   315→\tcurrent_node_panel.add_child(_current_biome_label)\n   316→\tmap_vbox.add_child(current_node_panel)\n   317→\n   318→\t# Travel path indicator\n   319→\tvar path_label := Label.new()\n   320→\tpath_label.text = \"│\"\n   321→\tpath_label.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER\n   322→\tpath_label.add_theme_font_size_override(\"font_size\", 16)\n   323→\tpath_label.add_theme_color_override(\"font_color\", Color(\"#007A63\"))\n   324→\tmap_vbox.add_child(path_label)\n   325→\n   326→\t# Destination nodes row\n   327→\tvar dest_row := HBoxContainer.new()\n   328→\tdest_row.add_theme_constant_override(\"separation\", 12)\n   329→\tdest_row.alignment = BoxContainer.ALIGNMENT_CENTER\n   330→\tdest_row.size_flags_vertical = Control.SIZE_EXPAND_FILL\n   331→\tmap_vbox.add_child(dest_row)\n   332→\n   333→\t# Build biome destination buttons dynamically from BiomeRegistry\n   334→\t_biome_node_buttons.clear()\n   335→\t_biome_node_ids.clear()\n   336→\n   337→\tfor biome_id: String in BiomeRegistry.BIOME_IDS:\n   338→\t\tif biome_id == NavigationSystem.current_biome:\n   339→\t\t\tcontinue\n   340→\t\t_biome_node_ids.append(biome_id)\n   341→\t\tvar biome_button := _build_biome_node_button(biome_id)\n   342→\t\tdest_row.add_child(biome_button)\n   343→\t\t_biome_node_buttons[biome_id] = biome_button\n   344→\n   345→\treturn col\n   346→\n   347→func _build_biome_node_button(biome_id: String) -> PanelContainer:\n   348→\tvar biome_data: BiomeData = BiomeRegistry.get_biome(biome_id)\n   349→\tvar display_name: String = biome_data.display_name if biome_data else biome_id\n   350→\n   351→\tvar panel := PanelContainer.new()\n   352→\tpanel.custom_minimum_size = Vector2(140, 80)\n   353→\tvar normal_style := StyleBoxFlat.new()\n   354→\tnormal_style.bg_color = COLOR_NODE_BG\n   355→\tnormal_style.border_color = Color(\"#1A2736\")\n   356→\tnormal_style.set_border_width_all(1)\n   357→\tnormal_style.set_corner_radius_all(4)\n   358→\tnormal_style.set_content_margin_all(8)\n   359→\tpanel.add_theme_stylebox_override(\"panel\", normal_style)\n   360→\n   361→\tvar vbox := VBoxContainer.new()\n   362→\tvbox.add_theme_constant_override(\"separation\", 2)\n   363→\tpanel.add_child(vbox)\n   364→\n   365→\t# Biome name\n   366→\tvar name_label := Label.new()\n   367→\tname_label.text = display_name\n   368→\tname_label.add_theme_font_size_override(\"font_size\", 16)\n   369→\tname_label.add_theme_color_override(\"font_color\", COLOR_TEXT_PRIMARY)\n   370→\tname_label.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER\n   371→\tvbox.add_child(name_label)\n   372→\n   373→\t# Distance\n   374→\tvar distance: float = BiomeRegistry.get_distance(NavigationSystem.current_biome, biome_id)\n   375→\tvar distance_km: float = distance / 100.0\n   376→\tvar distance_label := Label.new()\n   377→\tdistance_label.text = \"%.1f km\" % distance_km\n   378→\tdistance_label.add_theme_font_size_override(\"font_size\", 14)\n   379→\tdistance_label.add_theme_color_override(\"font_color\", COLOR_TEXT_SECONDARY)\n   380→\tdistance_label.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER\n   381→\tvbox.add_child(distance_label)\n   382→\n   383→\t# Fuel cost\n   384→\tvar fuel_cost: float = NavigationSystem.get_travel_cost(biome_id)\n   385→\tvar fuel_cells: int = ceili(fuel_cost / FuelSystemDefs.FUEL_CELL_UNITS)\n   386→\tvar fuel_label := Label.new()\n   387→\tfuel_label.text = \"%d Fuel Cell(s)\" % fuel_cells\n   388→\tfuel_label.add_theme_font_size_override(\"font_size\", 14)\n   389→\tfuel_label.add_theme_color_override(\"font_color\", COLOR_TEXT_SECONDARY)\n   390→\tfuel_label.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER\n   391→\tvbox.add_child(fuel_label)\n   392→\n   393→\t# Make the panel clickable via an invisible button overlay\n   394→\tvar click_button := Button.new()\n   395→\tclick_button.flat = true\n   396→\tclick_button.set_anchors_preset(Control.PRESET_FULL_RECT)\n   397→\tclick_button.mouse_filter = Control.MOUSE_FILTER_STOP\n   398→\tclick_button.focus_mode = Control.FOCUS_NONE\n   399→\tclick_button.pressed.connect(_on_biome_node_clicked.bind(biome_id))\n   400→\tpanel.add_child(click_button)\n   401→\n   402→\treturn panel\n   403→\n   404→func _build_detail_column() -> ScrollContainer:\n   405→\tvar scroll := ScrollContainer.new()\n   406→\tscroll.custom_minimum_size = Vector2(DETAIL_WIDTH, 0)\n   407→\tscroll.size_flags_horizontal = Control.SIZE_EXPAND_FILL\n   408→\tscroll.size_flags_vertical = Control.SIZE_EXPAND_FILL\n   409→\tscroll.horizontal_scroll_mode = ScrollContainer.SCROLL_MODE_DISABLED\n   410→\n   411→\tvar col := VBoxContainer.new()\n   412→\tcol.size_flags_horizontal = Control.SIZE_EXPAND_FILL\n   413→\tcol.add_theme_constant_override(\"separation\", 8)\n   414→\tscroll.add_child(col)\n   415→\n   416→\t# SHIP FUEL section — always visible when panel is open\n   417→\tvar fuel_header := Label.new()\n   418→\tfuel_header.text = \"SHIP FUEL\"\n   419→\tfuel_header.add_theme_font_size_override(\"font_size\", 14)\n   420→\tfuel_header.add_theme_color_override(\"font_color\", COLOR_TEXT_SECONDARY)\n   421→\tcol.add_child(fuel_header)\n   422→\n   423→\t_fuel_tank_level_label = Label.new()\n   424→\t_fuel_tank_level_label.add_theme_font_size_override(\"font_size\", 20)\n   425→\t_fuel_tank_level_label.add_theme_color_override(\"font_color\", COLOR_TEXT_PRIMARY)\n   426→\tcol.add_child(_fuel_tank_level_label)\n   427→\n   428→\t_fuel_inventory_count_label = Label.new()\n   429→\t_fuel_inventory_count_label.add_theme_font_size_override(\"font_size\", 14)\n   430→\t_fuel_inventory_count_label.add_theme_color_override(\"font_color\", COLOR_TEXT_SECONDARY)\n   431→\tcol.add_child(_fuel_inventory_count_label)\n   432→\n   433→\t_load_fuel_button = Button.new()\n   434→\t_load_fuel_button.text = \"LOAD FUEL CELLS\"\n   435→\t_load_fuel_button.custom_minimum_size = Vector2(200, 40)\n   436→\t_load_fuel_button.add_theme_font_size_override(\"font_size\", 16)\n   437→\t_style_teal_button(_load_fuel_button)\n   438→\t_load_fuel_button.pressed.connect(_on_load_fuel_pressed)\n   439→\tcol.add_child(_load_fuel_button)\n   440→\n   441→\t_fuel_status_label = Label.new()\n   442→\t_fuel_status_label.add_theme_font_size_override(\"font_size\", 14)\n   443→\t_fuel_status_label.add_theme_color_override(\"font_color\", COLOR_GREEN)\n   444→\t_fuel_status_label.visible = false\n   445→\tcol.add_child(_fuel_status_label)\n   446→\n   447→\t_add_divider(col)\n   448→\n   449→\t# Section header\n   450→\tvar header := Label.new()\n   451→\theader.text = \"DESTINATION\"\n   452→\theader.add_theme_font_size_override(\"font_size\", 14)\n   453→\theader.add_theme_color_override(\"font_color\", COLOR_TEXT_SECONDARY)\n   454→\tcol.add_child(header)\n   455→\n   456→\t_add_divider(col)\n   457→\n   458→\t# Empty state prompt\n   459→\t_detail_prompt_label = Label.new()\n   460→\t_detail_prompt_label.text = \"Select a destination\"\n   461→\t_detail_prompt_label.add_theme_font_size_override(\"font_size\", 16)\n   462→\t_detail_prompt_label.add_theme_color_override(\"font_color\", COLOR_TEXT_SECONDARY)\n   463→\tcol.add_child(_detail_prompt_label)\n   464→\n   465→\t# Destination name\n   466→\t_detail_name_label = Label.new()\n   467→\t_detail_name_label.add_theme_font_size_override(\"font_size\", 24)\n   468→\t_detail_name_label.add_theme_color_override(\"font_color\", COLOR_TEAL)\n   469→\t_detail_name_label.visible = false\n   470→\tcol.add_child(_detail_name_label)\n   471→\n   472→\t# Tier badge\n   473→\t_detail_tier_label = Label.new()\n   474→\t_detail_tier_label.add_theme_font_size_override(\"font_size\", 14)\n   475→\t_detail_tier_label.add_theme_color_override(\"font_color\", COLOR_TEXT_SECONDARY)\n   476→\t_detail_tier_label.visible = false\n   477→\tcol.add_child(_detail_tier_label)\n   478→\n   479→\t_add_divider(col)\n   480→\n   481→\t# Distance row\n   482→\t_detail_distance_label = Label.new()\n   483→\t_detail_distance_label.text = \"Distance\"\n   484→\t_detail_distance_label.add_theme_font_size_override(\"font_size\", 14)\n   485→\t_detail_distance_label.add_theme_color_override(\"font_color\", COLOR_TEXT_SECONDARY)\n   486→\t_detail_distance_label.visible = false\n   487→\tcol.add_child(_detail_distance_label)\n   488→\n   489→\t_detail_distance_value = Label.new()\n   490→\t_detail_distance_value.add_theme_font_size_override(\"font_size\", 22)\n   491→\t_detail_distance_value.add_theme_color_override(\"font_color\", COLOR_TEXT_PRIMARY)\n   492→\t_detail_distance_value.visible = false\n   493→\tcol.add_child(_detail_distance_value)\n   494→\n   495→\t# Fuel cost row\n   496→\t_detail_fuel_cost_label = Label.new()\n   497→\t_detail_fuel_cost_label.text = \"Estimated Fuel Cost\"\n   498→\t_detail_fuel_cost_label.add_theme_font_size_override(\"font_size\", 14)\n   499→\t_detail_fuel_cost_label.add_theme_color_override(\"font_color\", COLOR_TEXT_SECONDARY)\n   500→\t_detail_fuel_cost_label.visible = false\n   501→\tcol.add_child(_detail_fuel_cost_label)\n   502→\n   503→\t_detail_fuel_cost_value = Label.new()\n   504→\t_detail_fuel_cost_value.add_theme_font_size_override(\"font_size\", 22)\n   505→\t_detail_fuel_cost_value.add_theme_color_override(\"font_color\", COLOR_TEXT_PRIMARY)\n   506→\t_detail_fuel_cost_value.visible = false\n   507→\tcol.add_child(_detail_fuel_cost_value)\n   508→\n   509→\t# Your fuel row\n   510→\t_detail_your_fuel_label = Label.new()\n   511→\t_detail_your_fuel_label.text = \"Ship Tank\"\n   512→\t_detail_your_fuel_label.add_theme_font_size_override(\"font_size\", 14)\n   513→\t_detail_your_fuel_label.add_theme_color_override(\"font_color\", COLOR_TEXT_SECONDARY)\n   514→\t_detail_your_fuel_label.visible = false\n   515→\tcol.add_child(_detail_your_fuel_label)\n   516→\n   517→\t_detail_your_fuel_value = Label.new()\n   518→\t_detail_your_fuel_value.add_theme_font_size_override(\"font_size\", 22)\n   519→\t_detail_your_fuel_value.visible = false\n   520→\tcol.add_child(_detail_your_fuel_value)\n   521→\n   522→\t# Sufficiency indicator\n   523→\t_detail_sufficiency_label = Label.new()\n   524→\t_detail_sufficiency_label.add_theme_font_size_override(\"font_size\", 14)\n   525→\t_detail_sufficiency_label.visible = false\n   526→\tcol.add_child(_detail_sufficiency_label)\n   527→\n   528→\t_add_divider(col)\n   529→\n   530→\t# Confirm travel button\n   531→\tvar button_center := CenterContainer.new()\n   532→\tcol.add_child(button_center)\n   533→\n   534→\t_confirm_button = Button.new()\n   535→\t_confirm_button.text = \"CONFIRM TRAVEL\"\n   536→\t_confirm_button.custom_minimum_size = Vector2(240, 52)\n   537→\t_confirm_button.add_theme_font_size_override(\"font_size\", 20)\n   538→\t_confirm_button.disabled = true\n   539→\t_style_teal_button(_confirm_button)\n   540→\t_confirm_button.pressed.connect(_on_confirm_pressed)\n   541→\tbutton_center.add_child(_confirm_button)\n   542→\n   543→\t# Disabled reason label\n   544→\t_confirm_disabled_reason = Label.new()\n   545→\t_confirm_disabled_reason.add_theme_font_size_override(\"font_size\", 14)\n   546→\t_confirm_disabled_reason.add_theme_color_override(\"font_color\", COLOR_CORAL)\n   547→\t_confirm_disabled_reason.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER\n   548→\t_confirm_disabled_reason.visible = false\n   549→\tcol.add_child(_confirm_disabled_reason)\n   550→\n   551→\treturn scroll\n   552→\n   553→func _build_action_bar(parent: VBoxContainer) -> void:\n   554→\tvar bar := HBoxContainer.new()\n   555→\tbar.custom_minimum_size = Vector2(0, ACTION_HEIGHT)\n   556→\tbar.alignment = BoxContainer.ALIGNMENT_CENTER\n   557→\tbar.add_theme_constant_override(\"separation\", 16)\n   558→\tparent.add_child(bar)\n   559→\n   560→\tvar instructions := Label.new()\n   561→\tinstructions.text = \"[Arrows] Select  [Enter] Confirm  [Esc] Close\"\n   562→\tinstructions.add_theme_font_size_override(\"font_size\", 14)\n   563→\tinstructions.add_theme_color_override(\"font_color\", COLOR_TEXT_SECONDARY)\n   564→\tbar.add_child(instructions)\n   565→\n   566→\t_cancel_button = Button.new()\n   567→\t_cancel_button.text = \"CANCEL\"\n   568→\t_cancel_button.custom_minimum_size = Vector2(120, 40)\n   569→\t_cancel_button.add_theme_font_size_override(\"font_size\", 20)\n   570→\t_style_secondary_button(_cancel_button)\n   571→\t_cancel_button.pressed.connect(close_panel)\n   572→\tbar.add_child(_cancel_button)\n   573→\n   574→func _connect_signals() -> void:\n   575→\tFuelSystem.fuel_changed.connect(_on_fuel_changed)\n   576→\n   577→func _clamp_panel_to_viewport() -> void:\n   578→\tvar max_height: float = get_viewport().get_visible_rect().size.y * 0.92\n   579→\t_main_panel.custom_minimum_size.y = min(PANEL_HEIGHT, max_height)\n   580→\n   581→func _refresh_biome_nodes() -> void:\n   582→\t# Update current biome display\n   583→\tvar current_data: BiomeData = BiomeRegistry.get_biome(NavigationSystem.current_biome)\n   584→\tvar current_name: String = current_data.display_name if current_data else NavigationSystem.current_biome\n   585→\t_current_biome_label.text = \"◉ %s\" % current_name.to_upper()\n   586→\t_update_map_visuals()\n   587→\n   588→func _update_map_visuals() -> void:\n   589→\tfor i: int in range(_biome_node_ids.size()):\n   590→\t\tvar biome_id: String = _biome_node_ids[i]\n   591→\t\tvar panel: PanelContainer = _biome_node_buttons[biome_id]\n   592→\t\tvar style: StyleBoxFlat = panel.get_theme_stylebox(\"panel\") as StyleBoxFlat\n   593→\t\tvar name_label: Label = panel.get_child(0).get_child(0) as Label\n   594→\n   595→\t\tvar is_focused: bool = _focus_on_map and i == _selected_index\n   596→\t\tvar is_selected: bool = biome_id == _selected_biome_id\n   597→\n   598→\t\tif is_selected or is_focused:\n   599→\t\t\tstyle.bg_color = COLOR_NODE_BG_SELECTED\n   600→\t\t\tstyle.border_color = COLOR_TEAL\n   601→\t\t\tstyle.set_border_width_all(2)\n   602→\t\t\tif is_selected:\n   603→\t\t\t\tname_label.add_theme_color_override(\"font_color\", COLOR_TEAL)\n   604→\t\t\telse:\n   605→\t\t\t\tname_label.add_theme_color_override(\"font_color\", COLOR_TEXT_PRIMARY)\n   606→\t\telse:\n   607→\t\t\tstyle.bg_color = COLOR_NODE_BG\n   608→\t\t\tstyle.border_color = Color(\"#1A2736\")\n   609→\t\t\tstyle.set_border_width_all(1)\n   610→\t\t\tname_label.add_theme_color_override(\"font_color\", COLOR_TEXT_PRIMARY)\n   611→\n   612→func _select_biome(biome_id: String) -> void:\n   613→\t_selected_biome_id = biome_id\n   614→\t# Update selected_index to match\n   615→\tfor i: int in range(_biome_node_ids.size()):\n   616→\t\tif _biome_node_ids[i] == biome_id:\n   617→\t\t\t_selected_index = i\n   618→\t\t\tbreak\n   619→\t_update_map_visuals()\n   620→\t_refresh_detail()\n   621→\tGlobal.log(\"NavigationConsole: selected destination '%s'\" % biome_id)\n   622→\n   623→func _refresh_detail() -> void:\n   624→\tif _selected_biome_id.is_empty():\n   625→\t\t# Empty state\n   626→\t\t_detail_prompt_label.visible = true\n   627→\t\t_detail_name_label.visible = false\n   628→\t\t_detail_tier_label.visible = false\n   629→\t\t_detail_distance_label.visible = false\n   630→\t\t_detail_distance_value.visible = false\n   631→\t\t_detail_fuel_cost_label.visible = false\n   632→\t\t_detail_fuel_cost_value.visible = false\n   633→\t\t_detail_your_fuel_label.visible = false\n   634→\t\t_detail_your_fuel_value.visible = false\n   635→\t\t_detail_sufficiency_label.visible = false\n   636→\t\t_confirm_button.disabled = true\n   637→\t\t_confirm_disabled_reason.visible = false\n   638→\t\treturn\n   639→\n   640→\t_detail_prompt_label.visible = false\n   641→\n   642→\tvar biome_data: BiomeData = BiomeRegistry.get_biome(_selected_biome_id)\n   643→\tif not biome_data:\n   644→\t\treturn\n   645→\n   646→\t# Name\n   647→\t_detail_name_label.text = biome_data.display_name\n   648→\t_detail_name_label.visible = true\n   649→\n   650→\t# Tier\n   651→\t_detail_tier_label.text = \"── Tier 1 ──\"\n   652→\t_detail_tier_label.visible = true\n   653→\n   654→\t# Distance\n   655→\tvar distance: float = BiomeRegistry.get_distance(NavigationSystem.current_biome, _selected_biome_id)\n   656→\tvar distance_km: float = distance / 100.0\n   657→\t_detail_distance_label.visible = true\n   658→\t_detail_distance_value.text = \"%.1f km\" % distance_km\n   659→\t_detail_distance_value.visible = true\n   660→\n   661→\t# Fuel cost\n   662→\tvar fuel_cost: float = NavigationSystem.get_travel_cost(_selected_biome_id)\n   663→\tvar fuel_cells_needed: int = ceili(fuel_cost / FuelSystemDefs.FUEL_CELL_UNITS)\n   664→\t_detail_fuel_cost_label.visible = true\n   665→\t_detail_fuel_cost_value.text = \"%d Fuel Cell(s)\" % fuel_cells_needed\n   666→\t_detail_fuel_cost_value.visible = true\n   667→\n   668→\t# Your fuel\n   669→\tvar current_fuel: float = FuelSystem.fuel_current\n   670→\tvar your_fuel_cells: int = floori(current_fuel / FuelSystemDefs.FUEL_CELL_UNITS)\n   671→\t_detail_your_fuel_label.visible = true\n   672→\t_detail_your_fuel_value.text = \"%d Fuel Cell(s)\" % your_fuel_cells\n   673→\t_detail_your_fuel_value.visible = true\n   674→\n   675→\t# Sufficiency check\n   676→\tvar can_afford: bool = NavigationSystem.can_travel_to(_selected_biome_id)\n   677→\tif can_afford:\n   678→\t\t_detail_your_fuel_value.add_theme_color_override(\"font_color\", COLOR_GREEN)\n   679→\t\t_detail_sufficiency_label.text = \"● Sufficient\"\n   680→\t\t_detail_sufficiency_label.add_theme_color_override(\"font_color\", COLOR_GREEN)\n   681→\t\t_confirm_button.disabled = false\n   682→\t\t_confirm_disabled_reason.visible = false\n   683→\telse:\n   684→\t\t_detail_your_fuel_value.add_theme_color_override(\"font_color\", COLOR_CORAL)\n   685→\t\t_detail_sufficiency_label.text = \"⚠ Not enough fuel\"\n   686→\t\t_detail_sufficiency_label.add_theme_color_override(\"font_color\", COLOR_CORAL)\n   687→\t\t_confirm_button.disabled = true\n   688→\t\tvar deficit: int = fuel_cells_needed - your_fuel_cells\n   689→\t\t_confirm_disabled_reason.text = \"Need %d more Fuel Cell(s)\" % deficit\n   690→\t\t_confirm_disabled_reason.visible = true\n   691→\t_detail_sufficiency_label.visible = true\n   692→\n   693→func _move_map_focus(direction: int) -> void:\n   694→\tif _biome_node_ids.is_empty():\n   695→\t\treturn\n   696→\tvar new_index: int = clampi(_selected_index + direction, 0, _biome_node_ids.size() - 1)\n   697→\tif new_index != _selected_index:\n   698→\t\t_selected_index = new_index\n   699→\t\t_update_map_visuals()\n   700→\n   701→func _on_biome_node_clicked(biome_id: String) -> void:\n   702→\t# Mouse click selects destination immediately\n   703→\t_select_biome(biome_id)\n   704→\n   705→func _on_confirm_pressed() -> void:\n   706→\tif _selected_biome_id.is_empty():\n   707→\t\tGlobal.log(\"NavigationConsole: confirm pressed — no destination selected\")\n   708→\t\treturn\n   709→\tif not NavigationSystem.can_travel_to(_selected_biome_id):\n   710→\t\tGlobal.log(\"NavigationConsole: confirm pressed — cannot afford travel to '%s'\" % _selected_biome_id)\n   711→\t\treturn\n   712→\n   713→\tvar destination: String = _selected_biome_id\n   714→\tGlobal.log(\"NavigationConsole: confirming travel to '%s'\" % destination)\n   715→\ttravel_confirmed.emit(destination)\n   716→\n   717→\t# Close the panel first without re-enabling gameplay inputs — the\n   718→\t# TravelSequenceManager owns the input state during the transition and\n   719→\t# will re-enable inputs when the sequence completes.\n   720→\t_close_for_travel()\n   721→\n   722→\t# Initiate travel — the NavigationSystem state machine runs synchronously,\n   723→\t# emitting travel_completed which triggers TravelSequenceManager's async\n   724→\t# biome transition (fade out -> swap -> fade in -> re-enable inputs).\n   725→\tNavigationSystem.initiate_travel(destination)\n   726→\tGlobal.log(\"NavigationConsole: travel initiated to '%s'\" % destination)\n   727→\n   728→func _on_fuel_changed(_current: float, _maximum: float) -> void:\n   729→\tif _is_open:\n   730→\t\t_refresh_detail()\n   731→\t\t_refresh_fuel_section()\n   732→\n   733→func _refresh_fuel_section() -> void:\n   734→\tvar current_fuel: float = FuelSystem.fuel_current\n   735→\tvar max_fuel: float = FuelSystem.fuel_max\n   736→\t_fuel_tank_level_label.text = \"%d / %d units\" % [int(current_fuel), int(max_fuel)]\n   737→\n   738→\tvar cells_in_inventory: int = PlayerInventory.get_total_count(ResourceDefs.ResourceType.FUEL_CELL)\n   739→\t_fuel_inventory_count_label.text = \"Cells in backpack: %d\" % cells_in_inventory\n   740→\n   741→\tvar tank_is_full: bool = current_fuel >= max_fuel\n   742→\t_load_fuel_button.disabled = cells_in_inventory == 0 or tank_is_full\n   743→\n   744→func _on_load_fuel_pressed() -> void:\n   745→\tvar cells_available: int = PlayerInventory.get_total_count(ResourceDefs.ResourceType.FUEL_CELL)\n   746→\tif cells_available == 0:\n   747→\t\treturn\n   748→\tvar cells_consumed: int = FuelSystem.refuel(cells_available)\n   749→\tif cells_consumed > 0:\n   750→\t\tvar units_added: float = cells_consumed * FuelSystemDefs.FUEL_CELL_UNITS\n   751→\t\t_fuel_status_label.text = \"Loaded %d cell(s) (+%d units)\" % [cells_consumed, int(units_added)]\n   752→\t\t_fuel_status_label.add_theme_color_override(\"font_color\", COLOR_GREEN)\n   753→\t\t_fuel_status_label.visible = true\n   754→\t\tGlobal.log(\"NavigationConsole: loaded %d fuel cell(s) into ship tank\" % cells_consumed)\n   755→\telse:\n   756→\t\t_fuel_status_label.text = \"Tank is already full\"\n   757→\t\t_fuel_status_label.add_theme_color_override(\"font_color\", COLOR_AMBER)\n   758→\t\t_fuel_status_label.visible = true\n   759→\n   760→func _style_teal_button(button: Button) -> void:\n   761→\tvar normal_style := StyleBoxFlat.new()\n   762→\tnormal_style.bg_color = Color(COLOR_TEAL, 0.2)\n   763→\tnormal_style.border_color = COLOR_TEAL\n   764→\tnormal_style.set_border_width_all(2)\n   765→\tnormal_style.set_corner_radius_all(4)\n   766→\tnormal_style.set_content_margin_all(8)\n   767→\tbutton.add_theme_stylebox_override(\"normal\", normal_style)\n   768→\tbutton.add_theme_stylebox_override(\"hover\", normal_style)\n   769→\n   770→\tvar pressed_style: StyleBoxFlat = normal_style.duplicate() as StyleBoxFlat\n   771→\tpressed_style.bg_color = Color(COLOR_TEAL, 0.4)\n   772→\tbutton.add_theme_stylebox_override(\"pressed\", pressed_style)\n   773→\n   774→\tvar disabled_style: StyleBoxFlat = normal_style.duplicate() as StyleBoxFlat\n   775→\tdisabled_style.bg_color = Color(COLOR_TEAL, 0.05)\n   776→\tdisabled_style.border_color = Color(COLOR_NEUTRAL, 0.4)\n   777→\tbutton.add_theme_stylebox_override(\"disabled\", disabled_style)\n   778→\n   779→\tvar focus_style: StyleBoxFlat = normal_style.duplicate() as StyleBoxFlat\n   780→\tfocus_style.border_color = COLOR_TEAL\n   781→\tfocus_style.set_border_width_all(2)\n   782→\tbutton.add_theme_stylebox_override(\"focus\", focus_style)\n   783→\n   784→\tbutton.add_theme_color_override(\"font_color\", COLOR_TEAL)\n   785→\tbutton.add_theme_color_override(\"font_hover_color\", COLOR_TEXT_PRIMARY)\n   786→\tbutton.add_theme_color_override(\"font_disabled_color\", Color(COLOR_NEUTRAL, 0.4))\n   787→\n   788→func _style_secondary_button(button: Button) -> void:\n   789→\tvar normal_style := StyleBoxFlat.new()\n   790→\tnormal_style.bg_color = Color(COLOR_NEUTRAL, 0.2)\n   791→\tnormal_style.border_color = Color(\"#007A63\")\n   792→\tnormal_style.set_border_width_all(1)\n   793→\tnormal_style.set_corner_radius_all(4)\n   794→\tnormal_style.set_content_margin_all(8)\n   795→\tbutton.add_theme_stylebox_override(\"normal\", normal_style)\n   796→\tbutton.add_theme_stylebox_override(\"hover\", normal_style)\n   797→\n   798→\tvar pressed_style: StyleBoxFlat = normal_style.duplicate() as StyleBoxFlat\n   799→\tpressed_style.bg_color = Color(COLOR_NEUTRAL, 0.4)\n   800→\tbutton.add_theme_stylebox_override(\"pressed\", pressed_style)\n   801→\n   802→\tbutton.add_theme_color_override(\"font_color\", COLOR_NEUTRAL)\n   803→\tbutton.add_theme_color_override(\"font_hover_color\", COLOR_TEXT_PRIMARY)\n   804→\n   805→func _add_divider(parent: Node) -> void:\n   806→\tvar divider := HSeparator.new()\n   807→\tvar div_style := StyleBoxFlat.new()\n   808→\tdiv_style.bg_color = Color(COLOR_NEUTRAL, 0.4)\n   809→\tdiv_style.set_content_margin_all(0)\n   810→\tdivider.add_theme_stylebox_override(\"separator\", div_style)\n   811→\tparent.add_child(divider)\n   812→\n   813→func _animate_open() -> void:\n   814→\t_dim_rect.modulate.a = 0.0\n   815→\t_main_panel.modulate.a = 0.0\n   816→\t_main_panel.scale = Vector2(0.95, 0.95)\n   817→\tvar tween: Tween = create_tween()\n   818→\ttween.set_parallel(true)\n   819→\ttween.tween_property(_dim_rect, \"modulate:a\", 1.0, 0.15)\n   820→\ttween.tween_property(_main_panel, \"modulate:a\", 1.0, 0.2)\n   821→\ttween.tween_property(_main_panel, \"scale\", Vector2.ONE, 0.2).set_ease(Tween.EASE_OUT)\n   822→\n   823→func _animate_close() -> void:\n   824→\tvar tween: Tween = create_tween()\n   825→\ttween.set_parallel(true)\n   826→\ttween.tween_property(_dim_rect, \"modulate:a\", 0.0, 0.15)\n   827→\ttween.tween_property(_main_panel, \"modulate:a\", 0.0, 0.15)\n   828→\ttween.tween_callback(func() -> void: visible = false)\n   829→"}]},"parent_tool_use_id":null,"session_id":"e95448fc-7558-4157-960a-6c7229146ac9","uuid":"982be49f-c4ce-44ee-ad84-3d112dbf936c","tool_use_result":{"type":"text","file":{"filePath":"C:\\repos\\Hammer-Forge-Studio\\.claude\\worktrees\\orch-gameplay-programmer-TICKET-0247\\game\\scripts\\ui\\navigation_console.gd","content":"## Navigation console modal: displays biome map, destination detail, fuel cost,\n## and confirm travel button. Opens when the player interacts with the cockpit\n## console mesh. Follows existing modal panel pattern (Fabricator, TechTree).\n## Owner: gameplay-programmer\n## Ticket: TICKET-0167\nclass_name NavigationConsole\nextends CanvasLayer\n\n# ── Signals ──────────────────────────────────────────────\nsignal travel_confirmed(destination_biome_id: String)\nsignal panel_closed\n\n# ── Constants ─────────────────────────────────────────────\nconst PANEL_WIDTH: float = 900.0\nconst PANEL_HEIGHT: float = 600.0\nconst MAP_WIDTH: float = 540.0\nconst DETAIL_WIDTH: float = 300.0\nconst TITLE_HEIGHT: float = 56.0\nconst ACTION_HEIGHT: float = 60.0\n\n## Style colors matching UI style guide\nconst COLOR_SURFACE := Color(\"#0A0F18\", 0.95)\nconst COLOR_BORDER := Color(\"#007A63\")\nconst COLOR_TEAL := Color(\"#00D4AA\")\nconst COLOR_AMBER := Color(\"#FFB830\")\nconst COLOR_CORAL := Color(\"#FF6B5A\")\nconst COLOR_GREEN := Color(\"#4ADE80\")\nconst COLOR_TEXT_PRIMARY := Color(\"#F1F5F9\")\nconst COLOR_TEXT_SECONDARY := Color(\"#94A3B8\")\nconst COLOR_NEUTRAL := Color(\"#94A3B8\")\nconst COLOR_DIM := Color(\"#000000\", 0.5)\nconst COLOR_PANEL_BG := Color(\"#0F1923\", 0.85)\nconst COLOR_NODE_BG := Color(\"#1A2736\", 0.7)\nconst COLOR_NODE_BG_SELECTED := Color(\"#1A2736\", 0.9)\n\n# ── Private Variables ─────────────────────────────────────\nvar _is_open: bool = false\nvar _dim_rect: ColorRect = null\nvar _main_panel: PanelContainer = null\nvar _selected_biome_id: String = \"\"\nvar _biome_node_buttons: Dictionary = {}\nvar _biome_node_ids: Array[String] = []\nvar _selected_index: int = -1\nvar _focus_on_map: bool = true\n\n## Detail panel elements\nvar _detail_name_label: Label = null\nvar _detail_tier_label: Label = null\nvar _detail_distance_label: Label = null\nvar _detail_distance_value: Label = null\nvar _detail_fuel_cost_label: Label = null\nvar _detail_fuel_cost_value: Label = null\nvar _detail_your_fuel_label: Label = null\nvar _detail_your_fuel_value: Label = null\nvar _detail_sufficiency_label: Label = null\nvar _confirm_button: Button = null\nvar _confirm_disabled_reason: Label = null\nvar _cancel_button: Button = null\nvar _detail_prompt_label: Label = null\nvar _detail_container: ScrollContainer = null\n\n## Ship fuel section elements\nvar _fuel_tank_level_label: Label = null\nvar _fuel_inventory_count_label: Label = null\nvar _load_fuel_button: Button = null\nvar _fuel_status_label: Label = null\n\n## Current biome node display\nvar _current_biome_label: Label = null\n\n# ── Built-in Virtual Methods ──────────────────────────────\n\nfunc _ready() -> void:\n\tlayer = 2\n\tprocess_mode = Node.PROCESS_MODE_INHERIT\n\tvisible = false\n\t_build_ui()\n\t_connect_signals()\n\nfunc _input(event: InputEvent) -> void:\n\tif not _is_open:\n\t\treturn\n\tif event.is_action_pressed(\"ui_cancel\"):\n\t\tclose_panel()\n\t\tget_viewport().set_input_as_handled()\n\t\treturn\n\n\tif _focus_on_map:\n\t\tif event.is_action_pressed(\"ui_left\"):\n\t\t\t_move_map_focus(-1)\n\t\t\tget_viewport().set_input_as_handled()\n\t\telif event.is_action_pressed(\"ui_right\"):\n\t\t\t_move_map_focus(1)\n\t\t\tget_viewport().set_input_as_handled()\n\t\telif event.is_action_pressed(\"ui_down\"):\n\t\t\t# Move focus from map to confirm/cancel buttons\n\t\t\t_focus_on_map = false\n\t\t\tif _confirm_button and not _confirm_button.disabled:\n\t\t\t\t_confirm_button.grab_focus()\n\t\t\telif _cancel_button:\n\t\t\t\t_cancel_button.grab_focus()\n\t\t\tget_viewport().set_input_as_handled()\n\t\telif event.is_action_pressed(\"ui_up\"):\n\t\t\t_move_map_focus(-1)\n\t\t\tget_viewport().set_input_as_handled()\n\t\telif event.is_action_pressed(\"ui_accept\"):\n\t\t\t# Select focused destination and shift focus to confirm button\n\t\t\tif _selected_index >= 0:\n\t\t\t\t_select_biome(_biome_node_ids[_selected_index])\n\t\t\t\t_focus_on_map = false\n\t\t\t\tif _confirm_button and not _confirm_button.disabled:\n\t\t\t\t\t_confirm_button.grab_focus()\n\t\t\t\telif _cancel_button:\n\t\t\t\t\t_cancel_button.grab_focus()\n\t\t\tget_viewport().set_input_as_handled()\n\telse:\n\t\tif event.is_action_pressed(\"ui_up\") or event.is_action_pressed(\"ui_left\"):\n\t\t\t_focus_on_map = true\n\t\t\t_update_map_visuals()\n\t\t\tget_viewport().set_input_as_handled()\n\t\telif event.is_action_pressed(\"ui_down\"):\n\t\t\t# Move between confirm and cancel\n\t\t\tif _cancel_button:\n\t\t\t\t_cancel_button.grab_focus()\n\t\t\tget_viewport().set_input_as_handled()\n\t\telif event.is_action_pressed(\"ui_accept\"):\n\t\t\tif _confirm_button and _confirm_button.has_focus() and not _confirm_button.disabled:\n\t\t\t\t_on_confirm_pressed()\n\t\t\telif _cancel_button and _cancel_button.has_focus():\n\t\t\t\tclose_panel()\n\t\t\tget_viewport().set_input_as_handled()\n\n# ── Public Methods ────────────────────────────────────────\n\n## Opens the navigation console panel and resets to no-selection state.\nfunc open_panel() -> void:\n\tif _is_open:\n\t\treturn\n\t_is_open = true\n\tvisible = true\n\t_selected_biome_id = \"\"\n\t_selected_index = -1\n\t_focus_on_map = true\n\t_clamp_panel_to_viewport()\n\t_refresh_biome_nodes()\n\t_refresh_detail()\n\t_refresh_fuel_section()\n\t# Auto-focus first available destination node\n\tif _biome_node_ids.size() > 0:\n\t\t_selected_index = 0\n\t\t_update_map_visuals()\n\tInputManager.set_gameplay_inputs_enabled(false)\n\tInput.set_mouse_mode(Input.MOUSE_MODE_VISIBLE)\n\t_animate_open()\n\tGlobal.log(\"NavigationConsole: opened\")\n\n## Closes the navigation console panel and restores input handling.\nfunc close_panel() -> void:\n\tif not _is_open:\n\t\treturn\n\t_is_open = false\n\tInputManager.set_gameplay_inputs_enabled(true)\n\tInput.set_mouse_mode(Input.MOUSE_MODE_CAPTURED)\n\t_animate_close()\n\tpanel_closed.emit()\n\tGlobal.log(\"NavigationConsole: closed\")\n\n## Closes the panel for travel without re-enabling gameplay inputs.\n## The TravelSequenceManager owns the input state during the transition\n## and will call InputManager.set_gameplay_inputs_enabled(true) when the\n## travel sequence completes.\nfunc _close_for_travel() -> void:\n\tif not _is_open:\n\t\treturn\n\t_is_open = false\n\tInput.set_mouse_mode(Input.MOUSE_MODE_CAPTURED)\n\t_animate_close()\n\tpanel_closed.emit()\n\tGlobal.log(\"NavigationConsole: closed for travel (inputs left disabled)\")\n\n## Returns true if the panel is currently open.\nfunc is_open() -> bool:\n\treturn _is_open\n\n# ── Private Methods ───────────────────────────────────────\n\nfunc _build_ui() -> void:\n\t# Dim background\n\tvar dim_layer := Control.new()\n\tdim_layer.set_anchors_preset(Control.PRESET_FULL_RECT)\n\tdim_layer.mouse_filter = Control.MOUSE_FILTER_STOP\n\tadd_child(dim_layer)\n\n\t_dim_rect = ColorRect.new()\n\t_dim_rect.set_anchors_preset(Control.PRESET_FULL_RECT)\n\t_dim_rect.color = COLOR_DIM\n\tdim_layer.add_child(_dim_rect)\n\n\tvar center := CenterContainer.new()\n\tcenter.set_anchors_preset(Control.PRESET_FULL_RECT)\n\tdim_layer.add_child(center)\n\n\t# Main panel\n\t_main_panel = PanelContainer.new()\n\t_main_panel.custom_minimum_size = Vector2(PANEL_WIDTH, PANEL_HEIGHT)\n\t_main_panel.pivot_offset = Vector2(PANEL_WIDTH / 2.0, PANEL_HEIGHT / 2.0)\n\tvar panel_style := StyleBoxFlat.new()\n\tpanel_style.bg_color = COLOR_SURFACE\n\tpanel_style.border_color = COLOR_BORDER\n\tpanel_style.set_border_width_all(1)\n\tpanel_style.set_corner_radius_all(8)\n\tpanel_style.set_content_margin_all(24)\n\t_main_panel.add_theme_stylebox_override(\"panel\", panel_style)\n\tcenter.add_child(_main_panel)\n\n\tvar outer_vbox := VBoxContainer.new()\n\touter_vbox.add_theme_constant_override(\"separation\", 0)\n\t_main_panel.add_child(outer_vbox)\n\n\t# Title bar\n\t_build_title_bar(outer_vbox)\n\t_add_divider(outer_vbox)\n\n\t# Content area: map (left) + detail (right)\n\tvar content_hbox := HBoxContainer.new()\n\tcontent_hbox.add_theme_constant_override(\"separation\", 16)\n\tcontent_hbox.size_flags_vertical = Control.SIZE_EXPAND_FILL\n\touter_vbox.add_child(content_hbox)\n\n\t# Left column: biome map\n\tvar map_column := _build_map_column()\n\tcontent_hbox.add_child(map_column)\n\n\t# Vertical divider\n\tvar v_divider := VSeparator.new()\n\tvar vdiv_style := StyleBoxFlat.new()\n\tvdiv_style.bg_color = Color(COLOR_NEUTRAL, 0.3)\n\tvdiv_style.set_content_margin_all(0)\n\tv_divider.add_theme_stylebox_override(\"separator\", vdiv_style)\n\tcontent_hbox.add_child(v_divider)\n\n\t# Right column: destination detail\n\t_detail_container = _build_detail_column()\n\tcontent_hbox.add_child(_detail_container)\n\n\t# Action bar (bottom)\n\t_add_divider(outer_vbox)\n\t_build_action_bar(outer_vbox)\n\nfunc _build_title_bar(parent: VBoxContainer) -> void:\n\tvar title_row := HBoxContainer.new()\n\ttitle_row.custom_minimum_size = Vector2(0, TITLE_HEIGHT)\n\ttitle_row.add_theme_constant_override(\"separation\", 8)\n\tparent.add_child(title_row)\n\n\tvar title := Label.new()\n\ttitle.text = \"NAVIGATION CONSOLE\"\n\ttitle.add_theme_font_size_override(\"font_size\", 32)\n\ttitle.add_theme_color_override(\"font_color\", COLOR_TEXT_PRIMARY)\n\ttitle.size_flags_horizontal = Control.SIZE_EXPAND_FILL\n\ttitle.vertical_alignment = VERTICAL_ALIGNMENT_CENTER\n\ttitle_row.add_child(title)\n\n\tvar close_button := Button.new()\n\tclose_button.text = \"CLOSE\"\n\tclose_button.custom_minimum_size = Vector2(80, 32)\n\tclose_button.add_theme_font_size_override(\"font_size\", 16)\n\t_style_secondary_button(close_button)\n\tclose_button.pressed.connect(close_panel)\n\ttitle_row.add_child(close_button)\n\nfunc _build_map_column() -> VBoxContainer:\n\tvar col := VBoxContainer.new()\n\tcol.custom_minimum_size = Vector2(MAP_WIDTH, 0)\n\tcol.size_flags_horizontal = Control.SIZE_EXPAND_FILL\n\tcol.add_theme_constant_override(\"separation\", 8)\n\n\t# Map section header\n\tvar header := Label.new()\n\theader.text = \"BIOME MAP\"\n\theader.add_theme_font_size_override(\"font_size\", 14)\n\theader.add_theme_color_override(\"font_color\", COLOR_TEXT_SECONDARY)\n\tcol.add_child(header)\n\n\t# Map container with panel background\n\tvar map_panel := PanelContainer.new()\n\tmap_panel.size_flags_vertical = Control.SIZE_EXPAND_FILL\n\tvar map_bg := StyleBoxFlat.new()\n\tmap_bg.bg_color = COLOR_PANEL_BG\n\tmap_bg.set_content_margin_all(20)\n\tmap_bg.set_corner_radius_all(4)\n\tmap_panel.add_theme_stylebox_override(\"panel\", map_bg)\n\tcol.add_child(map_panel)\n\n\tvar map_vbox := VBoxContainer.new()\n\tmap_vbox.add_theme_constant_override(\"separation\", 16)\n\tmap_panel.add_child(map_vbox)\n\n\t# Current location node (displayed at top of map)\n\t_current_biome_label = Label.new()\n\t_current_biome_label.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER\n\t_current_biome_label.add_theme_font_size_override(\"font_size\", 16)\n\t_current_biome_label.add_theme_color_override(\"font_color\", COLOR_TEAL)\n\n\tvar current_node_panel := PanelContainer.new()\n\tcurrent_node_panel.custom_minimum_size = Vector2(200, 40)\n\tvar current_style := StyleBoxFlat.new()\n\tcurrent_style.bg_color = Color(\"#1A2736\", 0.9)\n\tcurrent_style.border_color = COLOR_TEAL\n\tcurrent_style.set_border_width_all(2)\n\tcurrent_style.set_corner_radius_all(4)\n\tcurrent_style.set_content_margin_all(8)\n\tcurrent_node_panel.add_theme_stylebox_override(\"panel\", current_style)\n\tcurrent_node_panel.size_flags_horizontal = Control.SIZE_SHRINK_CENTER\n\tcurrent_node_panel.add_child(_current_biome_label)\n\tmap_vbox.add_child(current_node_panel)\n\n\t# Travel path indicator\n\tvar path_label := Label.new()\n\tpath_label.text = \"│\"\n\tpath_label.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER\n\tpath_label.add_theme_font_size_override(\"font_size\", 16)\n\tpath_label.add_theme_color_override(\"font_color\", Color(\"#007A63\"))\n\tmap_vbox.add_child(path_label)\n\n\t# Destination nodes row\n\tvar dest_row := HBoxContainer.new()\n\tdest_row.add_theme_constant_override(\"separation\", 12)\n\tdest_row.alignment = BoxContainer.ALIGNMENT_CENTER\n\tdest_row.size_flags_vertical = Control.SIZE_EXPAND_FILL\n\tmap_vbox.add_child(dest_row)\n\n\t# Build biome destination buttons dynamically from BiomeRegistry\n\t_biome_node_buttons.clear()\n\t_biome_node_ids.clear()\n\n\tfor biome_id: String in BiomeRegistry.BIOME_IDS:\n\t\tif biome_id == NavigationSystem.current_biome:\n\t\t\tcontinue\n\t\t_biome_node_ids.append(biome_id)\n\t\tvar biome_button := _build_biome_node_button(biome_id)\n\t\tdest_row.add_child(biome_button)\n\t\t_biome_node_buttons[biome_id] = biome_button\n\n\treturn col\n\nfunc _build_biome_node_button(biome_id: String) -> PanelContainer:\n\tvar biome_data: BiomeData = BiomeRegistry.get_biome(biome_id)\n\tvar display_name: String = biome_data.display_name if biome_data else biome_id\n\n\tvar panel := PanelContainer.new()\n\tpanel.custom_minimum_size = Vector2(140, 80)\n\tvar normal_style := StyleBoxFlat.new()\n\tnormal_style.bg_color = COLOR_NODE_BG\n\tnormal_style.border_color = Color(\"#1A2736\")\n\tnormal_style.set_border_width_all(1)\n\tnormal_style.set_corner_radius_all(4)\n\tnormal_style.set_content_margin_all(8)\n\tpanel.add_theme_stylebox_override(\"panel\", normal_style)\n\n\tvar vbox := VBoxContainer.new()\n\tvbox.add_theme_constant_override(\"separation\", 2)\n\tpanel.add_child(vbox)\n\n\t# Biome name\n\tvar name_label := Label.new()\n\tname_label.text = display_name\n\tname_label.add_theme_font_size_override(\"font_size\", 16)\n\tname_label.add_theme_color_override(\"font_color\", COLOR_TEXT_PRIMARY)\n\tname_label.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER\n\tvbox.add_child(name_label)\n\n\t# Distance\n\tvar distance: float = BiomeRegistry.get_distance(NavigationSystem.current_biome, biome_id)\n\tvar distance_km: float = distance / 100.0\n\tvar distance_label := Label.new()\n\tdistance_label.text = \"%.1f km\" % distance_km\n\tdistance_label.add_theme_font_size_override(\"font_size\", 14)\n\tdistance_label.add_theme_color_override(\"font_color\", COLOR_TEXT_SECONDARY)\n\tdistance_label.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER\n\tvbox.add_child(distance_label)\n\n\t# Fuel cost\n\tvar fuel_cost: float = NavigationSystem.get_travel_cost(biome_id)\n\tvar fuel_cells: int = ceili(fuel_cost / FuelSystemDefs.FUEL_CELL_UNITS)\n\tvar fuel_label := Label.new()\n\tfuel_label.text = \"%d Fuel Cell(s)\" % fuel_cells\n\tfuel_label.add_theme_font_size_override(\"font_size\", 14)\n\tfuel_label.add_theme_color_override(\"font_color\", COLOR_TEXT_SECONDARY)\n\tfuel_label.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER\n\tvbox.add_child(fuel_label)\n\n\t# Make the panel clickable via an invisible button overlay\n\tvar click_button := Button.new()\n\tclick_button.flat = true\n\tclick_button.set_anchors_preset(Control.PRESET_FULL_RECT)\n\tclick_button.mouse_filter = Control.MOUSE_FILTER_STOP\n\tclick_button.focus_mode = Control.FOCUS_NONE\n\tclick_button.pressed.connect(_on_biome_node_clicked.bind(biome_id))\n\tpanel.add_child(click_button)\n\n\treturn panel\n\nfunc _build_detail_column() -> ScrollContainer:\n\tvar scroll := ScrollContainer.new()\n\tscroll.custom_minimum_size = Vector2(DETAIL_WIDTH, 0)\n\tscroll.size_flags_horizontal = Control.SIZE_EXPAND_FILL\n\tscroll.size_flags_vertical = Control.SIZE_EXPAND_FILL\n\tscroll.horizontal_scroll_mode = ScrollContainer.SCROLL_MODE_DISABLED\n\n\tvar col := VBoxContainer.new()\n\tcol.size_flags_horizontal = Control.SIZE_EXPAND_FILL\n\tcol.add_theme_constant_override(\"separation\", 8)\n\tscroll.add_child(col)\n\n\t# SHIP FUEL section — always visible when panel is open\n\tvar fuel_header := Label.new()\n\tfuel_header.text = \"SHIP FUEL\"\n\tfuel_header.add_theme_font_size_override(\"font_size\", 14)\n\tfuel_header.add_theme_color_override(\"font_color\", COLOR_TEXT_SECONDARY)\n\tcol.add_child(fuel_header)\n\n\t_fuel_tank_level_label = Label.new()\n\t_fuel_tank_level_label.add_theme_font_size_override(\"font_size\", 20)\n\t_fuel_tank_level_label.add_theme_color_override(\"font_color\", COLOR_TEXT_PRIMARY)\n\tcol.add_child(_fuel_tank_level_label)\n\n\t_fuel_inventory_count_label = Label.new()\n\t_fuel_inventory_count_label.add_theme_font_size_override(\"font_size\", 14)\n\t_fuel_inventory_count_label.add_theme_color_override(\"font_color\", COLOR_TEXT_SECONDARY)\n\tcol.add_child(_fuel_inventory_count_label)\n\n\t_load_fuel_button = Button.new()\n\t_load_fuel_button.text = \"LOAD FUEL CELLS\"\n\t_load_fuel_button.custom_minimum_size = Vector2(200, 40)\n\t_load_fuel_button.add_theme_font_size_override(\"font_size\", 16)\n\t_style_teal_button(_load_fuel_button)\n\t_load_fuel_button.pressed.connect(_on_load_fuel_pressed)\n\tcol.add_child(_load_fuel_button)\n\n\t_fuel_status_label = Label.new()\n\t_fuel_status_label.add_theme_font_size_override(\"font_size\", 14)\n\t_fuel_status_label.add_theme_color_override(\"font_color\", COLOR_GREEN)\n\t_fuel_status_label.visible = false\n\tcol.add_child(_fuel_status_label)\n\n\t_add_divider(col)\n\n\t# Section header\n\tvar header := Label.new()\n\theader.text = \"DESTINATION\"\n\theader.add_theme_font_size_override(\"font_size\", 14)\n\theader.add_theme_color_override(\"font_color\", COLOR_TEXT_SECONDARY)\n\tcol.add_child(header)\n\n\t_add_divider(col)\n\n\t# Empty state prompt\n\t_detail_prompt_label = Label.new()\n\t_detail_prompt_label.text = \"Select a destination\"\n\t_detail_prompt_label.add_theme_font_size_override(\"font_size\", 16)\n\t_detail_prompt_label.add_theme_color_override(\"font_color\", COLOR_TEXT_SECONDARY)\n\tcol.add_child(_detail_prompt_label)\n\n\t# Destination name\n\t_detail_name_label = Label.new()\n\t_detail_name_label.add_theme_font_size_override(\"font_size\", 24)\n\t_detail_name_label.add_theme_color_override(\"font_color\", COLOR_TEAL)\n\t_detail_name_label.visible = false\n\tcol.add_child(_detail_name_label)\n\n\t# Tier badge\n\t_detail_tier_label = Label.new()\n\t_detail_tier_label.add_theme_font_size_override(\"font_size\", 14)\n\t_detail_tier_label.add_theme_color_override(\"font_color\", COLOR_TEXT_SECONDARY)\n\t_detail_tier_label.visible = false\n\tcol.add_child(_detail_tier_label)\n\n\t_add_divider(col)\n\n\t# Distance row\n\t_detail_distance_label = Label.new()\n\t_detail_distance_label.text = \"Distance\"\n\t_detail_distance_label.add_theme_font_size_override(\"font_size\", 14)\n\t_detail_distance_label.add_theme_color_override(\"font_color\", COLOR_TEXT_SECONDARY)\n\t_detail_distance_label.visible = false\n\tcol.add_child(_detail_distance_label)\n\n\t_detail_distance_value = Label.new()\n\t_detail_distance_value.add_theme_font_size_override(\"font_size\", 22)\n\t_detail_distance_value.add_theme_color_override(\"font_color\", COLOR_TEXT_PRIMARY)\n\t_detail_distance_value.visible = false\n\tcol.add_child(_detail_distance_value)\n\n\t# Fuel cost row\n\t_detail_fuel_cost_label = Label.new()\n\t_detail_fuel_cost_label.text = \"Estimated Fuel Cost\"\n\t_detail_fuel_cost_label.add_theme_font_size_override(\"font_size\", 14)\n\t_detail_fuel_cost_label.add_theme_color_override(\"font_color\", COLOR_TEXT_SECONDARY)\n\t_detail_fuel_cost_label.visible = false\n\tcol.add_child(_detail_fuel_cost_label)\n\n\t_detail_fuel_cost_value = Label.new()\n\t_detail_fuel_cost_value.add_theme_font_size_override(\"font_size\", 22)\n\t_detail_fuel_cost_value.add_theme_color_override(\"font_color\", COLOR_TEXT_PRIMARY)\n\t_detail_fuel_cost_value.visible = false\n\tcol.add_child(_detail_fuel_cost_value)\n\n\t# Your fuel row\n\t_detail_your_fuel_label = Label.new()\n\t_detail_your_fuel_label.text = \"Ship Tank\"\n\t_detail_your_fuel_label.add_theme_font_size_override(\"font_size\", 14)\n\t_detail_your_fuel_label.add_theme_color_override(\"font_color\", COLOR_TEXT_SECONDARY)\n\t_detail_your_fuel_label.visible = false\n\tcol.add_child(_detail_your_fuel_label)\n\n\t_detail_your_fuel_value = Label.new()\n\t_detail_your_fuel_value.add_theme_font_size_override(\"font_size\", 22)\n\t_detail_your_fuel_value.visible = false\n\tcol.add_child(_detail_your_fuel_value)\n\n\t# Sufficiency indicator\n\t_detail_sufficiency_label = Label.new()\n\t_detail_sufficiency_label.add_theme_font_size_override(\"font_size\", 14)\n\t_detail_sufficiency_label.visible = false\n\tcol.add_child(_detail_sufficiency_label)\n\n\t_add_divider(col)\n\n\t# Confirm travel button\n\tvar button_center := CenterContainer.new()\n\tcol.add_child(button_center)\n\n\t_confirm_button = Button.new()\n\t_confirm_button.text = \"CONFIRM TRAVEL\"\n\t_confirm_button.custom_minimum_size = Vector2(240, 52)\n\t_confirm_button.add_theme_font_size_override(\"font_size\", 20)\n\t_confirm_button.disabled = true\n\t_style_teal_button(_confirm_button)\n\t_confirm_button.pressed.connect(_on_confirm_pressed)\n\tbutton_center.add_child(_confirm_button)\n\n\t# Disabled reason label\n\t_confirm_disabled_reason = Label.new()\n\t_confirm_disabled_reason.add_theme_font_size_override(\"font_size\", 14)\n\t_confirm_disabled_reason.add_theme_color_override(\"font_color\", COLOR_CORAL)\n\t_confirm_disabled_reason.horizontal_alignment = HORIZONTAL_ALIGNMENT_CENTER\n\t_confirm_disabled_reason.visible = false\n\tcol.add_child(_confirm_disabled_reason)\n\n\treturn scroll\n\nfunc _build_action_bar(parent: VBoxContainer) -> void:\n\tvar bar := HBoxContainer.new()\n\tbar.custom_minimum_size = Vector2(0, ACTION_HEIGHT)\n\tbar.alignment = BoxContainer.ALIGNMENT_CENTER\n\tbar.add_theme_constant_override(\"separation\", 16)\n\tparent.add_child(bar)\n\n\tvar instructions := Label.new()\n\tinstructions.text = \"[Arrows] Select  [Enter] Confirm  [Esc] Close\"\n\tinstructions.add_theme_font_size_override(\"font_size\", 14)\n\tinstructions.add_theme_color_override(\"font_color\", COLOR_TEXT_SECONDARY)\n\tbar.add_child(instructions)\n\n\t_cancel_button = Button.new()\n\t_cancel_button.text = \"CANCEL\"\n\t_cancel_button.custom_minimum_size = Vector2(120, 40)\n\t_cancel_button.add_theme_font_size_override(\"font_size\", 20)\n\t_style_secondary_button(_cancel_button)\n\t_cancel_button.pressed.connect(close_panel)\n\tbar.add_child(_cancel_button)\n\nfunc _connect_signals() -> void:\n\tFuelSystem.fuel_changed.connect(_on_fuel_changed)\n\nfunc _clamp_panel_to_viewport() -> void:\n\tvar max_height: float = get_viewport().get_visible_rect().size.y * 0.92\n\t_main_panel.custom_minimum_size.y = min(PANEL_HEIGHT, max_height)\n\nfunc _refresh_biome_nodes() -> void:\n\t# Update current biome display\n\tvar current_data: BiomeData = BiomeRegistry.get_biome(NavigationSystem.current_biome)\n\tvar current_name: String = current_data.display_name if current_data else NavigationSystem.current_biome\n\t_current_biome_label.text = \"◉ %s\" % current_name.to_upper()\n\t_update_map_visuals()\n\nfunc _update_map_visuals() -> void:\n\tfor i: int in range(_biome_node_ids.size()):\n\t\tvar biome_id: String = _biome_node_ids[i]\n\t\tvar panel: PanelContainer = _biome_node_buttons[biome_id]\n\t\tvar style: StyleBoxFlat = panel.get_theme_stylebox(\"panel\") as StyleBoxFlat\n\t\tvar name_label: Label = panel.get_child(0).get_child(0) as Label\n\n\t\tvar is_focused: bool = _focus_on_map and i == _selected_index\n\t\tvar is_selected: bool = biome_id == _selected_biome_id\n\n\t\tif is_selected or is_focused:\n\t\t\tstyle.bg_color = COLOR_NODE_BG_SELECTED\n\t\t\tstyle.border_color = COLOR_TEAL\n\t\t\tstyle.set_border_width_all(2)\n\t\t\tif is_selected:\n\t\t\t\tname_label.add_theme_color_override(\"font_color\", COLOR_TEAL)\n\t\t\telse:\n\t\t\t\tname_label.add_theme_color_override(\"font_color\", COLOR_TEXT_PRIMARY)\n\t\telse:\n\t\t\tstyle.bg_color = COLOR_NODE_BG\n\t\t\tstyle.border_color = Color(\"#1A2736\")\n\t\t\tstyle.set_border_width_all(1)\n\t\t\tname_label.add_theme_color_override(\"font_color\", COLOR_TEXT_PRIMARY)\n\nfunc _select_biome(biome_id: String) -> void:\n\t_selected_biome_id = biome_id\n\t# Update selected_index to match\n\tfor i: int in range(_biome_node_ids.size()):\n\t\tif _biome_node_ids[i] == biome_id:\n\t\t\t_selected_index = i\n\t\t\tbreak\n\t_update_map_visuals()\n\t_refresh_detail()\n\tGlobal.log(\"NavigationConsole: selected destination '%s'\" % biome_id)\n\nfunc _refresh_detail() -> void:\n\tif _selected_biome_id.is_empty():\n\t\t# Empty state\n\t\t_detail_prompt_label.visible = true\n\t\t_detail_name_label.visible = false\n\t\t_detail_tier_label.visible = false\n\t\t_detail_distance_label.visible = false\n\t\t_detail_distance_value.visible = false\n\t\t_detail_fuel_cost_label.visible = false\n\t\t_detail_fuel_cost_value.visible = false\n\t\t_detail_your_fuel_label.visible = false\n\t\t_detail_your_fuel_value.visible = false\n\t\t_detail_sufficiency_label.visible = false\n\t\t_confirm_button.disabled = true\n\t\t_confirm_disabled_reason.visible = false\n\t\treturn\n\n\t_detail_prompt_label.visible = false\n\n\tvar biome_data: BiomeData = BiomeRegistry.get_biome(_selected_biome_id)\n\tif not biome_data:\n\t\treturn\n\n\t# Name\n\t_detail_name_label.text = biome_data.display_name\n\t_detail_name_label.visible = true\n\n\t# Tier\n\t_detail_tier_label.text = \"── Tier 1 ──\"\n\t_detail_tier_label.visible = true\n\n\t# Distance\n\tvar distance: float = BiomeRegistry.get_distance(NavigationSystem.current_biome, _selected_biome_id)\n\tvar distance_km: float = distance / 100.0\n\t_detail_distance_label.visible = true\n\t_detail_distance_value.text = \"%.1f km\" % distance_km\n\t_detail_distance_value.visible = true\n\n\t# Fuel cost\n\tvar fuel_cost: float = NavigationSystem.get_travel_cost(_selected_biome_id)\n\tvar fuel_cells_needed: int = ceili(fuel_cost / FuelSystemDefs.FUEL_CELL_UNITS)\n\t_detail_fuel_cost_label.visible = true\n\t_detail_fuel_cost_value.text = \"%d Fuel Cell(s)\" % fuel_cells_needed\n\t_detail_fuel_cost_value.visible = true\n\n\t# Your fuel\n\tvar current_fuel: float = FuelSystem.fuel_current\n\tvar your_fuel_cells: int = floori(current_fuel / FuelSystemDefs.FUEL_CELL_UNITS)\n\t_detail_your_fuel_label.visible = true\n\t_detail_your_fuel_value.text = \"%d Fuel Cell(s)\" % your_fuel_cells\n\t_detail_your_fuel_value.visible = true\n\n\t# Sufficiency check\n\tvar can_afford: bool = NavigationSystem.can_travel_to(_selected_biome_id)\n\tif can_afford:\n\t\t_detail_your_fuel_value.add_theme_color_override(\"font_color\", COLOR_GREEN)\n\t\t_detail_sufficiency_label.text = \"● Sufficient\"\n\t\t_detail_sufficiency_label.add_theme_color_override(\"font_color\", COLOR_GREEN)\n\t\t_confirm_button.disabled = false\n\t\t_confirm_disabled_reason.visible = false\n\telse:\n\t\t_detail_your_fuel_value.add_theme_color_override(\"font_color\", COLOR_CORAL)\n\t\t_detail_sufficiency_label.text = \"⚠ Not enough fuel\"\n\t\t_detail_sufficiency_label.add_theme_color_override(\"font_color\", COLOR_CORAL)\n\t\t_confirm_button.disabled = true\n\t\tvar deficit: int = fuel_cells_needed - your_fuel_cells\n\t\t_confirm_disabled_reason.text = \"Need %d more Fuel Cell(s)\" % deficit\n\t\t_confirm_disabled_reason.visible = true\n\t_detail_sufficiency_label.visible = true\n\nfunc _move_map_focus(direction: int) -> void:\n\tif _biome_node_ids.is_empty():\n\t\treturn\n\tvar new_index: int = clampi(_selected_index + direction, 0, _biome_node_ids.size() - 1)\n\tif new_index != _selected_index:\n\t\t_selected_index = new_index\n\t\t_update_map_visuals()\n\nfunc _on_biome_node_clicked(biome_id: String) -> void:\n\t# Mouse click selects destination immediately\n\t_select_biome(biome_id)\n\nfunc _on_confirm_pressed() -> void:\n\tif _selected_biome_id.is_empty():\n\t\tGlobal.log(\"NavigationConsole: confirm pressed — no destination selected\")\n\t\treturn\n\tif not NavigationSystem.can_travel_to(_selected_biome_id):\n\t\tGlobal.log(\"NavigationConsole: confirm pressed — cannot afford travel to '%s'\" % _selected_biome_id)\n\t\treturn\n\n\tvar destination: String = _selected_biome_id\n\tGlobal.log(\"NavigationConsole: confirming travel to '%s'\" % destination)\n\ttravel_confirmed.emit(destination)\n\n\t# Close the panel first without re-enabling gameplay inputs — the\n\t# TravelSequenceManager owns the input state during the transition and\n\t# will re-enable inputs when the sequence completes.\n\t_close_for_travel()\n\n\t# Initiate travel — the NavigationSystem state machine runs synchronously,\n\t# emitting travel_completed which triggers TravelSequenceManager's async\n\t# biome transition (fade out -> swap -> fade in -> re-enable inputs).\n\tNavigationSystem.initiate_travel(destination)\n\tGlobal.log(\"NavigationConsole: travel initiated to '%s'\" % destination)\n\nfunc _on_fuel_changed(_current: float, _maximum: float) -> void:\n\tif _is_open:\n\t\t_refresh_detail()\n\t\t_refresh_fuel_section()\n\nfunc _refresh_fuel_section() -> void:\n\tvar current_fuel: float = FuelSystem.fuel_current\n\tvar max_fuel: float = FuelSystem.fuel_max\n\t_fuel_tank_level_label.text = \"%d / %d units\" % [int(current_fuel), int(max_fuel)]\n\n\tvar cells_in_inventory: int = PlayerInventory.get_total_count(ResourceDefs.ResourceType.FUEL_CELL)\n\t_fuel_inventory_count_label.text = \"Cells in backpack: %d\" % cells_in_inventory\n\n\tvar tank_is_full: bool = current_fuel >= max_fuel\n\t_load_fuel_button.disabled = cells_in_inventory == 0 or tank_is_full\n\nfunc _on_load_fuel_pressed() -> void:\n\tvar cells_available: int = PlayerInventory.get_total_count(ResourceDefs.ResourceType.FUEL_CELL)\n\tif cells_available == 0:\n\t\treturn\n\tvar cells_consumed: int = FuelSystem.refuel(cells_available)\n\tif cells_consumed > 0:\n\t\tvar units_added: float = cells_consumed * FuelSystemDefs.FUEL_CELL_UNITS\n\t\t_fuel_status_label.text = \"Loaded %d cell(s) (+%d units)\" % [cells_consumed, int(units_added)]\n\t\t_fuel_status_label.add_theme_color_override(\"font_color\", COLOR_GREEN)\n\t\t_fuel_status_label.visible = true\n\t\tGlobal.log(\"NavigationConsole: loaded %d fuel cell(s) into ship tank\" % cells_consumed)\n\telse:\n\t\t_fuel_status_label.text = \"Tank is already full\"\n\t\t_fuel_status_label.add_theme_color_override(\"font_color\", COLOR_AMBER)\n\t\t_fuel_status_label.visible = true\n\nfunc _style_teal_button(button: Button) -> void:\n\tvar normal_style := StyleBoxFlat.new()\n\tnormal_style.bg_color = Color(COLOR_TEAL, 0.2)\n\tnormal_style.border_color = COLOR_TEAL\n\tnormal_style.set_border_width_all(2)\n\tnormal_style.set_corner_radius_all(4)\n\tnormal_style.set_content_margin_all(8)\n\tbutton.add_theme_stylebox_override(\"normal\", normal_style)\n\tbutton.add_theme_stylebox_override(\"hover\", normal_style)\n\n\tvar pressed_style: StyleBoxFlat = normal_style.duplicate() as StyleBoxFlat\n\tpressed_style.bg_color = Color(COLOR_TEAL, 0.4)\n\tbutton.add_theme_stylebox_override(\"pressed\", pressed_style)\n\n\tvar disabled_style: StyleBoxFlat = normal_style.duplicate() as StyleBoxFlat\n\tdisabled_style.bg_color = Color(COLOR_TEAL, 0.05)\n\tdisabled_style.border_color = Color(COLOR_NEUTRAL, 0.4)\n\tbutton.add_theme_stylebox_override(\"disabled\", disabled_style)\n\n\tvar focus_style: StyleBoxFlat = normal_style.duplicate() as StyleBoxFlat\n\tfocus_style.border_color = COLOR_TEAL\n\tfocus_style.set_border_width_all(2)\n\tbutton.add_theme_stylebox_override(\"focus\", focus_style)\n\n\tbutton.add_theme_color_override(\"font_color\", COLOR_TEAL)\n\tbutton.add_theme_color_override(\"font_hover_color\", COLOR_TEXT_PRIMARY)\n\tbutton.add_theme_color_override(\"font_disabled_color\", Color(COLOR_NEUTRAL, 0.4))\n\nfunc _style_secondary_button(button: Button) -> void:\n\tvar normal_style := StyleBoxFlat.new()\n\tnormal_style.bg_color = Color(COLOR_NEUTRAL, 0.2)\n\tnormal_style.border_color = Color(\"#007A63\")\n\tnormal_style.set_border_width_all(1)\n\tnormal_style.set_corner_radius_all(4)\n\tnormal_style.set_content_margin_all(8)\n\tbutton.add_theme_stylebox_override(\"normal\", normal_style)\n\tbutton.add_theme_stylebox_override(\"hover\", normal_style)\n\n\tvar pressed_style: StyleBoxFlat = normal_style.duplicate() as StyleBoxFlat\n\tpressed_style.bg_color = Color(COLOR_NEUTRAL, 0.4)\n\tbutton.add_theme_stylebox_override(\"pressed\", pressed_style)\n\n\tbutton.add_theme_color_override(\"font_color\", COLOR_NEUTRAL)\n\tbutton.add_theme_color_override(\"font_hover_color\", COLOR_TEXT_PRIMARY)\n\nfunc _add_divider(parent: Node) -> void:\n\tvar divider := HSeparator.new()\n\tvar div_style := StyleBoxFlat.new()\n\tdiv_style.bg_color = Color(COLOR_NEUTRAL, 0.4)\n\tdiv_style.set_content_margin_all(0)\n\tdivider.add_theme_stylebox_override(\"separator\", div_style)\n\tparent.add_child(divider)\n\nfunc _animate_open() -> void:\n\t_dim_rect.modulate.a = 0.0\n\t_main_panel.modulate.a = 0.0\n\t_main_panel.scale = Vector2(0.95, 0.95)\n\tvar tween: Tween = create_tween()\n\ttween.set_parallel(true)\n\ttween.tween_property(_dim_rect, \"modulate:a\", 1.0, 0.15)\n\ttween.tween_property(_main_panel, \"modulate:a\", 1.0, 0.2)\n\ttween.tween_property(_main_panel, \"scale\", Vector2.ONE, 0.2).set_ease(Tween.EASE_OUT)\n\nfunc _animate_close() -> void:\n\tvar tween: Tween = create_tween()\n\ttween.set_parallel(true)\n\ttween.tween_property(_dim_rect, \"modulate:a\", 0.0, 0.15)\n\ttween.tween_property(_main_panel, \"modulate:a\", 0.0, 0.15)\n\ttween.tween_callback(func() -> void: visible = false)\n","numLines":829,"startLine":1,"totalLines":829}}},{"type":"assistant","message":{"model":"claude-haiku-4-5-20251001","id":"msg_01UEDqbf2jGsvxUHBovYMTRn","type":"message