lse:\n   941→                self.logger.log(\"WARNING\",\n   942→                    f\"Session-completion mismatch: {ticket_id} was recorded as done \"\n   943→                    f\"but ticket file reads {file_status} — evicting from session set\")\n   944→                evicted.append(ticket_id)\n   945→\n   946→        if evicted:\n   947→            self.state[\"completed_this_session\"] = still_valid\n   948→            self.logger.log(\"WARNING\",\n   949→                f\"Evicted {len(evicted)} ticket(s) from completed_this_session: \"\n   950→                + \", \".join(evicted))\n   951→\n   952→        return evicted\n   953→\n   954→    # ------------------------------------------------------------------\n   955→    # DISPATCHING\n   956→    # ------------------------------------------------------------------\n   957→\n   958→    async def _do_dispatching(self):\n   959→        \"\"\"Create worktrees and spawn workers for the planned wave.\"\"\"\n   960→        wave = self.state.pop(\"_pending_wave\", [])\n   961→        if not wave:\n   962→            self.state[\"status\"] = \"PLANNING\"\n   963→            return\n   964→\n   965→        # Process pending new tickets before spawning workers\n   966→        pending_tickets = self.state.pop(\"_pending_new_tickets\", [])\n   967→        for ticket_data in pending_tickets:\n   968→            tid = ticket_data.get(\"id\", \"UNKNOWN\")\n   969→            title = ticket_data.get(\"title\", \"\")\n   970→            written = write_ticket_file(\n   971→                ticket_data,\n   972→                self.state[\"milestone\"],\n   973→                self.state[\"wave_number\"],\n   974→                self.logger,\n   975→            )\n   976→            if written:\n   977→                self.logger.log(\"TICKET\", f\"Created {tid}: {title}\")\n   978→\n   979→        active_locks = self.state.get(\"active_ticket_ids\", [])\n   980→\n   981→        workers = []\n   982→        deferred = []  #