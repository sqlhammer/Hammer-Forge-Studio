Explicit orchestrator root. Falls back to $HFS_ORCH_DIR,\n    51→                  then to ``<repo_root>/orchestrator``.\n    52→\n    53→    Returns:\n    54→        A fully populated ``InstancePaths`` with directories created as needed.\n    55→    \"\"\"\n    56→    if orch_dir is None:\n    57→        env_dir = os.environ.get(\"HFS_ORCH_DIR\")\n    58→        if env_dir:\n    59→            orch_dir = Path(env_dir)\n    60→        else:\n    61→            # Walk up from this file to find the repo root (parent of orchestrator/)\n    62→            orch_dir = Path(__file__).resolve().parent\n    63→\n    64→    orch_dir = orch_dir.resolve()\n    65→    instance_dir = orch_dir / \"instances\" / instance_name\n    66→\n    67→    # Ensure per-instance directories exist\n    68→    (instance_dir / \"results\").mkdir(parents=True, exist_ok=True)\n    69→    (instance_dir / \"logs\").mkdir(parents=True, exist_ok=True)\n    70→\n    71→    return InstancePaths(\n    72→        orch_dir=orch_dir,\n    73→        instance_dir=instance_dir,\n    74→        # Global config\n    75→        config_path=orch_dir / \"config.json\",\n    76→        config_local_path=orch_dir / \"config.local.json\",\n    77→        # Per-instance state\n    78→        state_path=instance_dir / \"state.json\",\n    79→        activity_log=instance_dir / \"activity.log\",\n    80→        pending_gate_path=instance_dir / \"pending_gate.json\",\n    81→        gate_response_path=instance_dir / \"gate_response.json\",\n    82→        godot_mcp_lock_path=instance_dir / \"godot_mcp.lock\",\n    83→        # Per-instance output\n    84→        results_dir=instance_dir / \"results\",\n    85→        logs_dir=instance_dir / \"logs\",\n    86→        # Shared\n    87→        prompts_dir=orch_dir / \"prompts\",\n    88→        schemas_dir=orch_dir / \"schemas\",\n    89→    )\n    90→\n    91→\n    92→def load_config(paths: InstancePaths) -> dict:\n    93→    \"\"\"Load and merge orchestrator configuration