`orchestrator/status.py` to support `--instance <name>` (target a specific instance),","numLines":20,"startLine":1,"totalLines":62}}},{"type":"assistant","message":{"model":"claude-opus-4-6","id":"msg_01QqrL6CDko8DJ2Gf78LTkWk","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01U5R2cVwuH2F2uaDKqz2Sje","name":"Read","input":{"file_path":"C:\\repos\\Hammer-Forge-Studio\\orchestrator\\status.py"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1321,"cache_read_input_tokens":30480,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1321},"output_tokens":18,"service_tier":"standard","inference_geo":"not_available"},"context_management":null},"parent_tool_use_id":null,"session_id":"8786ba63-3b1f-40d6-a311-8337c51d41e5","uuid":"81478b3d-bc7a-466a-8599-7b580cb3f3f6"},{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01U5R2cVwuH2F2uaDKqz2Sje","type":"tool_result","content":"     1→#!/usr/bin/env python3\n     2→\"\"\"status.py — Display current orchestrator state.\n     3→\n     4→Usage:\n     5→    python orchestrator/status.py\n     6→    python orchestrator/status.py --json\n     7→    python orchestrator/status.py --instance <name>\n     8→    python orchestrator/status.py --all\n     9→\"\"\"\n    10→\n    11→import argparse\n    12→import json\n    13→import sys\n    14→from pathlib import Path\n    15→\n    16→from instance_paths import resolve_instance\n    17→\n    18→\n    19→ORCH_DIR = Path(__file__).resolve().parent\n    20→\n    21→\n    22→def format_cost(usd: float) -> str:\n    23→    return f\"${usd:.2f}\"\n    24→\n    25→\n    26→def _discover_instances() -> list[str]:\n    27→    \"\"\"Return sorted list of instance names that have a state.json file.\"\"\"\n    28→    instances_dir = ORCH_DIR / \"instances\"\n    29→    if not instances_dir.is_dir():\n    30→        return []\n    31→    return sorted(\n    32→        d.name\n    33→        for d in instances_dir.iterdir()\n    34→        if d.is_dir() and (d / \"state.json\").exists()\n    35→    )\n    36→\n    37→\n    38→def _load_state(state_path: Path) -> dict | None:\n    39→    \"\"\"Load and return state dict, or None if file missing.\"\"\"\n    40→    if not state_path.exists():\n    41→        return None\n    42→    with open(state_path, encoding=\"utf-8\") as f:\n    43→        return json.load(f)\n    44→\n    45→\n    46→def _print_one_line_summary(instance_name: str, state: dict) -> None:\n    47→    \"\"\"Print a single-line summary for --all output.\"\"\"\n    48→    milestone = state.get(\"milestone\", \"?\")\n    49→    phase = state.get(\"phase\", \"?\")\n    50→    wave = state.get(\"wave_number\", 0)\n    51→\n    52→    # Count tickets from completed waves + active workers\n    53→    completed_tickets = sum(\n    54→        len(w.get(\"tickets\", []))\n    55→        for w in state.get(\"completed_waves\", [])\n    56→    )\n    57→    active_tickets = len(state.get(\"active_workers\", []))\n    58→    total_tickets = completed_tickets + active_tickets\n    59→\n    60→    print(\n    61→        f\"  {instance_name:<12}  {milestone:<6}|  Phase: {phase:<16}|\"\n    62→        f\"  Wave: {wave:<4}|  Tickets: {completed_tickets}/{total_tickets} done\"\n    63→    )\n    64→\n    65→\n    66→def _print_full_status(instance_name: str, paths, state: dict, args) -> None:\n    67→    \"\"\"Print full status display for a single instance (preserves original format).\"\"\"\n    68→    if args.as_json:\n    69→        print(json.dumps(state, indent=2))\n    70→        return\n    71→\n    72→    print(\"=\" * 50)\n    73→    print(\"  Hammer Forge Studio — Orchestrator Status\")\n    74→    print(\"=\" * 50)\n    75→    print()\n    76→    print(f\"  Instance:   {instance_name}\")\n    77→    print(f\"  Status:     {state.get('status', '?')}\")\n    78→    print(f\"  Milestone:  {state.get('milestone', '?')}\")\n    79→    print(f\"  Phase:      {state.get('phase', '?')}\")\n    80→    print(f\"  Wave:       {state.get('wave_number', 0)}\")\n    81→    print(f\"  Started:    {state.get('started_at', '?')}\")\n    82→    print(f\"  Total cost: {format_cost(state.get('total_cost_usd', 0))}\")\n    83→    print()\n    84→\n    85→    # Active workers\n    86→    workers = state.get(\"active_workers\", [])\n    87→    if workers:\n    88→        print(f\"  Active workers ({len(workers)}):\")\n    89→        for w in workers:\n    90→            print(f\"    - {w.get('agent', '?')} -> {w.get('ticket', '?')}\"\n    91→                  f\" (budget={format_cost(w.get('budget_usd', 0))})\")\n    92→        print()\n    93→\n    94→    # Completed waves\n    95→    waves = state.get(\"completed_waves\", [])\n    96→    if waves:\n    97→        print(f\"  Completed waves ({len(waves)}):\")\n    98→        for w in waves:\n    99→            tickets = \", \".join(w.get(\"tickets\", []))\n   100→            print(f\"    Wave {w.get('wave', '?')}: [{tickets}]\"\n   101→                  f\" at {w.get('completed_at', '?')}\")\n   102→        print()\n   103→\n   104→    # Retries\n   105→    retries = state.get(\"retries\", {})\n   106→    if retries:\n   107→        print(\"  Retries:\")\n   108→        for tid, count in retries.items():\n   109→            print(f\"    {tid}: {count} attempt(s)\")\n   110→        print()\n   111→\n   112→    # Pending gate\n   113→    if paths.pending_gate_path.exists():\n   114→        with open(paths.pending_gate_path, encoding=\"utf-8\") as f:\n   115→            gate = json.load(f)\n   116→        print(\"  ** PENDING GATE **\")\n   117→        print(f\"    Phase:      {gate.get('phase', '?')}\")\n   118→        print(f\"    Next phase: {gate.get('next_phase', '?')}\")\n   119→        print(f\"    Summary:    {gate.get('summary', '')}\")\n   120→        print(f\"    Run: python orchestrator/approve_gate.py\")\n   121→        print()\n   122→\n   123→    # Activity log tail\n   124→    if args.log > 0 and paths.activity_log.exists():\n   125→        print(f\"  Last {args.log} log entries:\")\n   126→        lines = paths.activity_log.read_text(encoding=\"utf-8\").splitlines()\n   127→        for line in lines[-args.log:]:\n   128→            print(f\"    {line}\")\n   129→        print()\n   130→\n   131→\n   132→def main():\n   133→    parser = argparse.ArgumentParser(description=\"Show orchestrator status\")\n   134→    parser.add_argument(\"--json\", action=\"store_true\", dest=\"as_json\",\n   135→        help=\"Output raw JSON state\")\n   136→    parser.add_argument(\"--log\", type=int, default=0, metavar=\"N\",\n   137→        help=\"Show last N lines of activity log\")\n   138→    parser.add_argument(\"--instance\", type=str, default=None, metavar=\"NAME\",\n   139→        help=\"Target a specific instance by name\")\n   140→    parser.add_argument(\"--all\", action=\"store_true\", dest=\"show_all\",\n   141→        help=\"List all instances with a one-line summary each\")\n   142→    args = parser.parse_args()\n   143→\n   144→    # --all mode: list every instance with a summary line\n   145→    if args.show_all:\n   146→        instances = _discover_instances()\n   147→        if not instances:\n   148→            print(\"No instances found. Run start_milestone.py first.\")\n   149→            sys.exit(0)\n   150→        print(\"=\" * 50)\n   151→        print(\"  Hammer Forge Studio — All Instances\")\n   152→        print(\"=\" * 50)\n   153→        print()\n   154→        for name in instances:\n   155→            paths = resolve_instance(name, orch_dir=ORCH_DIR)\n   156→            state = _load_state(paths.state_path)\n   157→            if state:\n   158→                _print_one_line_summary(name, state)\n   159→        print()\n   160→        return\n   161→\n   162→    # Determine which instance to show\n   163→    if args.instance:\n   164→        instance_name = args.instance\n