e.ArgumentParser(description=\"Show orchestrator status\")\n   146→    parser.add_argument(\"--json\", action=\"store_true\", dest=\"as_json\",\n   147→        help=\"Output raw JSON state\")\n   148→    parser.add_argument(\"--log\", type=int, default=0, metavar=\"N\",\n   149→        help=\"Show last N lines of activity log\")\n   150→    parser.add_argument(\"--instance\", type=str, default=None, metavar=\"NAME\",\n   151→        help=\"Target a specific instance by name\")\n   152→    parser.add_argument(\"--all\", action=\"store_true\", dest=\"show_all\",\n   153→        help=\"List all instances with a one-line summary each\")\n   154→    args = parser.parse_args()\n   155→\n   156→    # --all mode: list every instance with a summary line\n   157→    if args.show_all:\n   158→        instances = _discover_instances()\n   159→        if not instances:\n   160→            print(\"No instances found. Run start_milestone.py first.\")\n   161→            sys.exit(0)\n   162→        print(\"=\" * 50)\n   163→        print(\"  Hammer Forge Studio — All Instances\")\n   164→        print(\"=\" * 50)\n   165→        print()\n   166→        for name in instances:\n   167→            paths = resolve_instance(name, orch_dir=ORCH_DIR)\n   168→            state = _load_state(paths.state_path)\n   169→            if state:\n   170→                _print_one_line_summary(name, state)\n   171→        print()\n   172→        return\n   173→\n   174→    # Determine which instance to show\n   175→    if args.instance:\n   176→        instance_name = args.instance\n   177→    else:\n   178→        # Auto-detect\n   179→        instances = _discover_instances()\n   180→        if len(instances) == 0:\n   181→            print(\"No instances found. Run start_milestone.py first.\")\n   182→            sys.exit(0)\n   183→        elif len(instances) == 1:\n   184→            instance_name = instances[0]\n   185→        else:\n   186→            print(f\"Multiple instances found ({len(