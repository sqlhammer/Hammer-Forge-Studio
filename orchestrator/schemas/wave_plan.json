{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Wave Plan",
  "description": "Producer output: the next wave of agent assignments, or a control action.",
  "type": "object",
  "required": ["action", "summary"],
  "properties": {
    "action": {
      "type": "string",
      "enum": ["spawn_agents", "no_work", "milestone_complete", "error"],
      "description": "What the conductor should do next."
    },
    "wave": {
      "type": "array",
      "description": "Agent assignments for this wave (required when action=spawn_agents).",
      "items": {
        "type": "object",
        "required": ["agent", "ticket", "budget_usd", "needs_worktree", "needs_godot_mcp"],
        "properties": {
          "agent": {
            "type": "string",
            "description": "Agent slug (e.g. 'gameplay-programmer')."
          },
          "ticket": {
            "type": "string",
            "description": "Ticket ID (e.g. 'TICKET-0090')."
          },
          "budget_usd": {
            "type": "number",
            "minimum": 0.01,
            "description": "Max budget for this worker invocation."
          },
          "needs_worktree": {
            "type": "boolean",
            "description": "True if this worker modifies code and needs git isolation."
          },
          "needs_godot_mcp": {
            "type": "boolean",
            "description": "True if this worker needs Godot MCP tools."
          },
          "prompt_supplement": {
            "type": "string",
            "description": "Optional extra instructions from the Producer to this worker."
          }
        },
        "additionalProperties": false
      }
    },
    "summary": {
      "type": "string",
      "description": "Human-readable summary of the planning decision."
    },
    "new_tickets": {
      "type": "array",
      "description": "Optional tickets to create before dispatching workers (permitted with action=spawn_agents only).",
      "items": {
        "type": "object",
        "required": ["id", "title", "type", "owner", "phase", "priority", "summary", "acceptance_criteria"],
        "properties": {
          "id": {
            "type": "string",
            "description": "Full ticket ID (e.g. 'TICKET-0155')."
          },
          "title": {
            "type": "string",
            "description": "Short descriptive title for the ticket."
          },
          "type": {
            "type": "string",
            "enum": ["TASK", "BUGFIX", "REVIEW", "BLOCKER", "SPIKE"],
            "description": "Ticket type."
          },
          "owner": {
            "type": "string",
            "description": "Agent slug (e.g. 'systems-programmer')."
          },
          "phase": {
            "type": "string",
            "description": "Milestone phase name."
          },
          "priority": {
            "type": "string",
            "enum": ["P0", "P1", "P2"],
            "description": "Ticket priority."
          },
          "depends_on": {
            "type": "array",
            "items": { "type": "string" },
            "default": [],
            "description": "List of ticket IDs this ticket depends on."
          },
          "summary": {
            "type": "string",
            "description": "One-sentence description of the ticket."
          },
          "acceptance_criteria": {
            "type": "array",
            "items": { "type": "string" },
            "description": "List of acceptance criteria lines."
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
